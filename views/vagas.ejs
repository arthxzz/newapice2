<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Encontre vagas de estágio e emprego para desenvolvedores, veja o roadmap de habilidades e candidate-se com confiança." />
  <link rel="icon" type="image/webp" href="/img/principal%28gradiente%29%20%281%29.webp" />
  <title>Dev Estágios — Vagas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/header.css" />
  <link rel="stylesheet" href="/css/vagas.css" />
  <link rel="stylesheet" href="/css/sidebar.css" />
</head>
<body class="<% if (locals.user) { %>app-shell<% } %>">

<% if (locals.user) { %>
  <%- include('partials/sidebar-dev', { currentPage: 'vagas' }) %>
  <div class="app-main">
  <%- include('partials/topbar', { topbarVariant: 'dev' }) %>
<% } else { %>
  <%- include('partials/header') %>
<% } %>

  <!-- ══════════ HERO ══════════ -->
  <section class="page-hero" aria-label="Vitrine de vagas">
    <div class="hero-eyebrow" aria-hidden="true">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      Vagas abertas
    </div>
    <h1 class="hero-title">
      Encontre sua vaga,<br>
      veja o <em>roadmap</em> exato
    </h1>
    <p class="hero-sub">
      Cada vaga tem uma trilha de aprendizado personalizada para o seu perfil. Saiba exatamente o que estudar antes de candidatar.
    </p>
    <div class="hero-stats" id="hero-stats" aria-label="Estatísticas">
      <div class="hstat">
        <div class="hstat-val" id="stat-vagas">—</div>
        <div class="hstat-lbl">Vagas abertas</div>
      </div>
      <div class="hstat-sep" aria-hidden="true"></div>
      <div class="hstat">
        <div class="hstat-val" id="stat-empresas">—</div>
        <div class="hstat-lbl">Empresas</div>
      </div>
      <div class="hstat-sep" aria-hidden="true"></div>
      <div class="hstat">
        <div class="hstat-val" id="stat-skills">—</div>
        <div class="hstat-lbl">Skills mapeadas</div>
      </div>
    </div>
  </section>

  <!-- ══════════ BANNER LOGIN (se não autenticado) ══════════ -->
  <div class="login-banner" id="login-banner" hidden>
    <div class="login-banner-inner" role="complementary" aria-label="Faça login para ver seu match">
      <div class="banner-text">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Entre com sua conta</strong> para ver seu % de match com cada vaga e acessar o roadmap personalizado.</span>
      </div>
      <a href="/login" class="btn-banner">
        Entrar agora
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>

  <!-- ══════════ FILTROS ══════════ -->
  <div class="filter-bar" role="search" aria-label="Filtrar vagas">
    <div class="filter-inner">

      <!-- Busca por texto -->
      <div class="search-wrap">
        <span class="search-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input
          type="search" id="q" class="search-input"
          placeholder="Buscar por título, empresa ou skill..."
          aria-label="Buscar vagas" autocomplete="off" />
      </div>

      <div class="filter-sep" aria-hidden="true"></div>

      <!-- Filtro por nível -->
      <div class="filter-group" role="group" aria-label="Nível">
        <button class="filter-chip active" data-filter="nivel" data-val="todos" aria-pressed="true">Todos</button>
        <button class="filter-chip" data-filter="nivel" data-val="estagio" aria-pressed="false">Estágio</button>
        <button class="filter-chip" data-filter="nivel" data-val="junior"  aria-pressed="false">Júnior</button>
        <button class="filter-chip" data-filter="nivel" data-val="pleno"   aria-pressed="false">Pleno</button>
      </div>

      <div class="filter-sep" aria-hidden="true"></div>

      <!-- Filtro por área -->
      <div class="filter-group" role="group" aria-label="Área">
        <button class="filter-chip active" data-filter="area" data-val="todas" aria-pressed="true">Todas</button>
        <button class="filter-chip" data-filter="area" data-val="backend"  aria-pressed="false">Backend</button>
        <button class="filter-chip" data-filter="area" data-val="frontend" aria-pressed="false">Frontend</button>
        <button class="filter-chip" data-filter="area" data-val="fullstack" aria-pressed="false">Fullstack</button>
      </div>

    </div>

    <!-- Contador e ordenação -->
    <div class="results-row">
      <p class="results-count" id="results-count" aria-live="polite"></p>
      <select class="sort-select" id="sort-select" aria-label="Ordenar vagas">
        <option value="id">Mais recentes</option>
        <option value="title">A → Z</option>
        <option value="company">Por empresa</option>
      </select>
    </div>
  </div>

  <!-- ══════════ GRID DE VAGAS ══════════ -->
  <main class="jobs-section" aria-label="Lista de vagas">
    <div class="jobs-grid" id="jobs-grid" role="list">
      <!-- Skeletons de loading -->
      <div class="skeleton-card" aria-hidden="true">
        <div class="skel skel-h" style="width:40%"></div>
        <div class="skel skel-h"></div>
        <div class="skel skel-sm"></div>
        <div class="skel skel-h" style="width:70%;height:10px"></div>
      </div>
      <div class="skeleton-card" aria-hidden="true">
        <div class="skel skel-h" style="width:55%"></div>
        <div class="skel skel-h"></div>
        <div class="skel skel-sm"></div>
        <div class="skel skel-h" style="width:80%;height:10px"></div>
      </div>
      <div class="skeleton-card" aria-hidden="true">
        <div class="skel skel-h" style="width:45%"></div>
        <div class="skel skel-h"></div>
        <div class="skel skel-sm"></div>
        <div class="skel skel-h" style="width:65%;height:10px"></div>
      </div>
    </div>
  </main>

  <% if (locals.user) { %>
  </div><%# /app-main %>
  <script src="/js/sidebar.js" defer></script>
  <% } %>

  <script>
    // ─── SVGs reutilizáveis ───────────────────────────────
    const IC = {
      zap:      `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
      briefcase:`<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
      settings: `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
      pentool:  `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
      wrench:   `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
      smartphone:`<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
      barchart: `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
      building: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/></svg>`,
      monitor:  `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
      users:    `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
      share:    `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>`,
      arrow:    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>`,
      search:   `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
    };

    // ─── Mapas ────────────────────────────────────────────
    const LEVEL_LABEL = { estagio:"Estágio", junior:"Júnior", pleno:"Pleno" };
    const LEVEL_CLASS = { estagio:"lvl-estagio", junior:"lvl-junior", pleno:"lvl-pleno" };

    function jobIcon(title) {
      const t = title.toLowerCase();
      if (t.includes("front"))                      return IC.pentool;
      if (t.includes("back"))                       return IC.settings;
      if (t.includes("full"))                       return IC.wrench;
      if (t.includes("mobile"))                     return IC.smartphone;
      if (t.includes("dados")||t.includes("data"))  return IC.barchart;
      return IC.briefcase;
    }

    // Detecta área da vaga pelo título
    function jobArea(title) {
      const t = title.toLowerCase();
      if (t.includes("front")) return "frontend";
      if (t.includes("back"))  return "backend";
      if (t.includes("full"))  return "fullstack";
      return "outros";
    }

    // ─── Estado global ────────────────────────────────────
    let allJobs     = [];
    let loggedIn    = false;
    let filterNivel = "todos";
    let filterArea  = "todas";
    let sortBy      = "id";
    let searchQuery = "";
    let searchTimer = null;

    // ─── Conta empresas únicas ────────────────────────────
    function countEmpresas(jobs) {
      return new Set(jobs.map(j => j.company).filter(Boolean)).size;
    }

    // ─── Conta skills únicas ──────────────────────────────
    function countSkills(jobs) {
      const ids = new Set();
      jobs.forEach(j => j.skills?.forEach(s => ids.add(s.id)));
      return ids.size;
    }

    // ─── Aplica filtros + ordenação ───────────────────────
    function applyFilters() {
      const q = searchQuery.trim().toLowerCase();

      let result = allJobs.filter(job => {
        if (filterNivel !== "todos" && job.level !== filterNivel) return false;
        if (filterArea  !== "todas" && jobArea(job.title) !== filterArea) return false;
        if (q) {
          const inTitle   = job.title.toLowerCase().includes(q);
          const inCompany = (job.company ?? "").toLowerCase().includes(q);
          const inDesc    = (job.description ?? "").toLowerCase().includes(q);
          const inSkill   = job.skills?.some(s => s.name.toLowerCase().includes(q));
          if (!inTitle && !inCompany && !inDesc && !inSkill) return false;
        }
        return true;
      });

      // Ordenação
      result = [...result].sort((a, b) => {
        if (sortBy === "title")   return a.title.localeCompare(b.title);
        if (sortBy === "company") return (a.company ?? "").localeCompare(b.company ?? "");
        return a.id - b.id;
      });

      renderCards(result);
      updateCount(result.length);
    }

    function updateCount(n) {
      const el = document.getElementById("results-count");
      el.innerHTML = `<strong>${n}</strong> vaga${n !== 1 ? "s" : ""} encontrada${n !== 1 ? "s" : ""}`;
    }

    // ─── Renderiza os cards ───────────────────────────────
    function renderCards(jobs) {
      const grid = document.getElementById("jobs-grid");
      grid.innerHTML = "";

      if (!jobs.length) {
        grid.innerHTML = `
          <div class="empty-state" role="status">
            <div class="empty-icon">${IC.search}</div>
            <p class="empty-title">Nenhuma vaga encontrada</p>
            <p class="empty-sub">Tente outros termos ou remova os filtros.</p>
          </div>`;
        return;
      }

      jobs.forEach((job, idx) => {
        const card = document.createElement("article");
        card.className = "job-card";
        card.setAttribute("role", "listitem");
        card.style.animationDelay = `${idx * 0.04}s`;

        // Separa hard skills obrigatórias, desejáveis e soft
        const hardObrig = job.skills?.filter(s => s.type === "hard" && s.importance === "obrigatoria") ?? [];
        const hardDesej = job.skills?.filter(s => s.type === "hard" && s.importance === "desejavel")  ?? [];
        const softSkills= job.skills?.filter(s => s.type === "soft") ?? [];

        const MAX_TAGS = 5;
        const allHard  = [...hardObrig, ...hardDesej];
        const visible  = allHard.slice(0, MAX_TAGS);
        const remaining= allHard.length - visible.length;

        const skillTagsHtml = visible.map(s => `
          <span class="skill-tag ${s.importance === "desejavel" ? "skill-tag-desejev" : ""}"
                title="${s.importance === "desejavel" ? "Desejável" : "Obrigatória"}">
            ${IC.monitor} ${s.name}
          </span>`).join("");

        const softHtml = softSkills.length ? softSkills.slice(0, 2).map(s => `
          <span class="skill-tag skill-tag-soft">${IC.users} ${s.name}</span>`).join("") : "";

        const moreHtml = remaining > 0
          ? `<span class="skills-more">+${remaining}</span>` : "";

        // CTA: se logado vai para /roadmap, senão para /login
        const ctaHref   = loggedIn ? `/roadmap?job=${job.id}` : `/login?next=/roadmap?job=${job.id}`;
        const ctaLabel  = loggedIn ? "Ver meu roadmap" : "Ver roadmap";

        card.innerHTML = `
          <div class="job-card-accent" aria-hidden="true"></div>
          <div class="job-card-body">

            <div class="job-card-top">
              <div class="job-icon-wrap" aria-hidden="true">${jobIcon(job.title)}</div>
              <div class="job-meta">
                <div class="job-title">${job.title}</div>
                <div class="job-company">
                  ${IC.building}
                  ${job.company ?? "Empresa"}
                </div>
              </div>
              <span class="level-badge ${LEVEL_CLASS[job.level] ?? "lvl-estagio"}"
                    aria-label="Nível: ${LEVEL_LABEL[job.level] ?? job.level}">
                ${LEVEL_LABEL[job.level] ?? job.level}
              </span>
            </div>

            ${job.description ? `<p class="job-desc">${job.description}</p>` : ""}

            ${allHard.length ? `
              <div class="skill-block">
                <div class="skill-block-label">Habilidades técnicas</div>
                <div class="skills-row" aria-label="Skills obrigatórias e desejáveis">
                  ${skillTagsHtml}${moreHtml}
                </div>
              </div>` : ""}

            ${softSkills.length ? `
              <div class="skill-block">
                <div class="skill-block-label">Habilidades comportamentais</div>
                <div class="skills-row" aria-label="Soft skills">${softHtml}</div>
              </div>` : ""}

          </div>

          <div class="job-card-footer">
            <a href="${ctaHref}" class="btn-roadmap" aria-label="${ctaLabel} para ${job.title}">
              ${ctaLabel} ${IC.arrow}
            </a>
            <button class="btn-share" aria-label="Compartilhar vaga" onclick="shareJob(event, ${job.id}, '${job.title.replace(/'/g,"\\'")}')">
              ${IC.share}
            </button>
          </div>`;

        grid.appendChild(card);
      });
    }

    // ─── Compartilhar vaga ────────────────────────────────
    function shareJob(e, id, title) {
      e.preventDefault();
      const url = `${location.origin}/vagas#job-${id}`;
      if (navigator.share) {
        navigator.share({ title: `${title} — Dev Estágios`, url });
      } else {
        navigator.clipboard.writeText(url).then(() => showToast("Link copiado!"));
      }
    }

    // ─── Toast leve ───────────────────────────────────────
    function showToast(msg) {
      const el = document.createElement("div");
      el.textContent = msg;
      Object.assign(el.style, {
        position:"fixed", bottom:"24px", right:"24px", zIndex:"999",
        padding:"10px 16px",
        background:"var(--bg-3)", border:"1px solid var(--border-lite)",
        borderRadius:"var(--radius-md)", fontSize:".85rem",
        color:"var(--text)", boxShadow:"0 8px 24px rgba(0,0,0,.4)",
        transition:"opacity .25s",
      });
      document.body.appendChild(el);
      setTimeout(() => { el.style.opacity = "0"; setTimeout(() => el.remove(), 300); }, 2200);
    }

    // ─── Filtros de nível ─────────────────────────────────
    document.querySelectorAll("[data-filter='nivel']").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll("[data-filter='nivel']").forEach(b => {
          b.classList.remove("active"); b.setAttribute("aria-pressed","false");
        });
        btn.classList.add("active"); btn.setAttribute("aria-pressed","true");
        filterNivel = btn.dataset.val;
        applyFilters();
      });
    });

    // ─── Filtros de área ──────────────────────────────────
    document.querySelectorAll("[data-filter='area']").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll("[data-filter='area']").forEach(b => {
          b.classList.remove("active"); b.setAttribute("aria-pressed","false");
        });
        btn.classList.add("active"); btn.setAttribute("aria-pressed","true");
        filterArea = btn.dataset.val;
        applyFilters();
      });
    });

    // ─── Ordenação ────────────────────────────────────────
    document.getElementById("sort-select").addEventListener("change", function () {
      sortBy = this.value;
      applyFilters();
    });

    // ─── Busca por texto ──────────────────────────────────
    document.getElementById("q").addEventListener("input", function () {
      searchQuery = this.value;
      clearTimeout(searchTimer);
      searchTimer = setTimeout(applyFilters, 220);
    });

    // ─── Bootstrap ───────────────────────────────────────
    async function init() {
      // Verifica login silenciosamente (não redireciona)
      try {
        const userRes = await fetch("/api/user");
        if (userRes.ok) {
          loggedIn = true;
          document.getElementById("login-banner").hidden = true;
        } else {
          document.getElementById("login-banner").hidden = false;
        }
      } catch { /* offline — continua como visitante */ }

      // Carrega vagas com skills
      try {
        const res = await fetch("/api/jobs/detalhes");
        if (!res.ok) throw new Error("Falha ao carregar vagas");
        allJobs = await res.json();

        // Atualiza stats do hero
        document.getElementById("stat-vagas").textContent    = allJobs.length;
        document.getElementById("stat-empresas").textContent = countEmpresas(allJobs);
        document.getElementById("stat-skills").textContent   = countSkills(allJobs);

        applyFilters();
      } catch (err) {
        document.getElementById("jobs-grid").innerHTML = `
          <div class="empty-state" role="alert">
            <div class="empty-icon">${IC.search}</div>
            <p class="empty-title">Erro ao carregar as vagas</p>
            <p class="empty-sub">Verifique sua conexão e recarregue a página.</p>
          </div>`;
        document.getElementById("results-count").textContent = "";
      }
    }

    init();
  </script>

</body>
</html>