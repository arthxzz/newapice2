<%#
  sidebar-company.ejs — Company area sidebar
  HubSpot/Jira-inspired · enterprise · structured
  Requires: locals.currentPage, locals.user
%>

<aside
  class="sidebar sidebar--company"
  id="sidebar-company"
  aria-label="Menu da empresa"
>

  <%# ── Header / Logo ──────────────────────────────────────── %>
  <header class="sidebar-header">
    <a
      href="/empresa/dashboard"
      class="sidebar-logo"
      aria-label="Ápice — ir para o dashboard da empresa"
    >
      <img src="/img/principal.webp" alt="Ápice" class="sidebar-logo-img" height="36" loading="eager" />
    </a>

    <button
      class="sidebar-collapse-btn"
      id="sidebar-company-toggle"
      type="button"
      aria-label="Recolher menu lateral"
      aria-expanded="true"
      aria-controls="sidebar-company"
    >
      <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M9 11L5 7L9 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </header>

  <%# ── Main Nav ────────────────────────────────────────────── %>
  <nav aria-label="Navegação principal da empresa">

    <span class="sidebar-section-label" aria-hidden="true">Principal</span>

    <ul class="sidebar-nav" role="list">

      <li>
        <a
          href="/empresa/dashboard"
          class="sidebar-link"
          data-tooltip="Dashboard"
          <% if (locals.currentPage === 'empresa-dashboard') { %>aria-current="page"<% } %>
        >
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="1.5" y="1.5" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <rect x="10.5" y="1.5" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <rect x="1.5" y="10.5" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <rect x="10.5" y="10.5" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
          </svg>
          <span class="sidebar-label">Dashboard</span>
        </a>
      </li>

      <li>
        <a
          href="/empresa/vagas"
          class="sidebar-link"
          data-tooltip="Vagas"
          <% if (locals.currentPage === 'empresa-vagas') { %>aria-current="page"<% } %>
        >
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="2" y="4" width="14" height="11" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <path d="M6 4V3C6 2.45 6.45 2 7 2H11C11.55 2 12 2.45 12 3V4" stroke="currentColor" stroke-width="1.4"/>
            <path d="M5 9H13M5 12H9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Vagas</span>
          <% if (locals.vagasAtivas) { %>
            <span class="sidebar-badge sidebar-badge--teal" aria-label="<%= vagasAtivas %> vagas ativas">
              <%= vagasAtivas %>
            </span>
          <% } %>
        </a>
      </li>

      <li>
        <a
          href="/empresa/desenvolvedores"
          class="sidebar-link"
          data-tooltip="Desenvolvedores"
          <% if (locals.currentPage === 'empresa-devs') { %>aria-current="page"<% } %>
        >
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="6" r="3" stroke="currentColor" stroke-width="1.4"/>
            <path d="M2 16C2 13.24 5.13 11 9 11C12.87 11 16 13.24 16 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Desenvolvedores</span>
        </a>
      </li>

      <li>
        <a
          href="/empresa/matchs"
          class="sidebar-link"
          data-tooltip="Matchs"
          <% if (locals.currentPage === 'empresa-matchs') { %>aria-current="page"<% } %>
        >
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M9 15L3.5 9.5C2.12 8.12 2.12 5.88 3.5 4.5C4.88 3.12 7.12 3.12 8.5 4.5L9 5L9.5 4.5C10.88 3.12 13.12 3.12 14.5 4.5C15.88 5.88 15.88 8.12 14.5 9.5L9 15Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
          </svg>
          <span class="sidebar-label">Matchs</span>
          <% if (locals.novosMatchs) { %>
            <span class="sidebar-badge sidebar-badge--purple" aria-label="<%= novosMatchs %> novos matchs">
              <%= novosMatchs %>
            </span>
          <% } %>
        </a>
      </li>

    </ul>

    <hr class="sidebar-divider" aria-hidden="true"/>

    <span class="sidebar-section-label" aria-hidden="true">Gestão</span>

    <ul class="sidebar-nav" role="list">

      <li>
        <a
          href="/empresa/relatorios"
          class="sidebar-link"
          data-tooltip="Relatórios"
          <% if (locals.currentPage === 'empresa-relatorios') { %>aria-current="page"<% } %>
        >
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="2" y="2" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.4"/>
            <path d="M5 12V9M8 12V7M11 12V5M14 12V10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Relatórios</span>
        </a>
      </li>

      <li>
        <a
          href="/empresa/financeiro"
          class="sidebar-link"
          data-tooltip="Financeiro"
          <% if (locals.currentPage === 'empresa-financeiro') { %>aria-current="page"<% } %>
        >
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.4"/>
            <path d="M9 5V6M9 12V13M6.5 7.5C6.5 6.67 7.17 6 8 6H10C10.83 6 11.5 6.67 11.5 7.5C11.5 8.33 10.83 9 10 9H8C7.17 9 6.5 9.67 6.5 10.5C6.5 11.33 7.17 12 8 12H10C10.83 12 11.5 11.33 11.5 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Financeiro</span>
        </a>
      </li>

    </ul>
  </nav>

  <%# ── Bottom Nav ──────────────────────────────────────────── %>
  <nav class="sidebar-bottom" aria-label="Configurações e conta da empresa">
    <ul class="sidebar-nav" role="list">
      <li>
        <a
          href="/empresa/perfil"
          class="sidebar-link"
          data-tooltip="Meu Perfil"
          <% if (locals.currentPage === 'perfil') { %>aria-current="page"<% } %>
        >
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="6" r="3" stroke="currentColor" stroke-width="1.4"/>
            <path d="M2.5 16c0-3.31 2.91-6 6.5-6s6.5 2.69 6.5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Meu Perfil</span>
        </a>
      </li>
    </ul>

    <%# Company Profile Card %>
    <% if (locals.user) { %>
    <a href="/empresa/perfil" class="sidebar-profile" aria-label="Ver perfil da empresa <%= user.company || user.name || '' %>">
      <% if (user.avatar) { %>
        <img
          src="<%= user.avatar %>"
          alt=""
          class="sidebar-avatar"
          width="32" height="32"
          loading="lazy"
          aria-hidden="true"
        />
      <% } else { %>
        <span class="sidebar-avatar-placeholder" aria-hidden="true">
          <%= (user.company || user.name || 'E').charAt(0).toUpperCase() %>
        </span>
      <% } %>
      <div class="sidebar-profile-info">
        <strong class="sidebar-profile-name"><%= user.company || user.name || 'Empresa' %></strong>
        <span class="sidebar-profile-role">Conta Empresa</span>
      </div>
    </a>
    <% } %>
  </nav>

</aside>

<%# ── Mobile Overlay ──────────────────────────────────────── %>
<div
  class="sidebar-overlay"
  id="sidebar-overlay"
  aria-hidden="true"
  role="presentation"
></div>
