<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Perfil da sua empresa na plataforma Ápice." />
  <title>Ápice — Perfil da Empresa</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/sidebar.css" />
  <link rel="stylesheet" href="/css/perfil.css" />
</head>

<body class="app-shell">

  <%- include('partials/sidebar-company', { currentPage: 'perfil', vagasAtivas: 0, novosMatchs: 0 }) %>

  <div class="app-main">
    <%- include('partials/topbar', { topbarVariant: 'company' }) %>

    <main class="app-content" id="main-content">
      <div class="perfil-layout">

        <!-- Loading skeleton -->
        <div id="state-loading" aria-label="Carregando perfil" aria-live="polite">
          <div class="skeleton-block skel-hero"></div>
          <div class="skeleton-block skel-card" style="margin-top:1.25rem"></div>
          <div class="skeleton-block skel-card-sm" style="margin-top:1.25rem"></div>
        </div>

        <!-- Content -->
        <div id="state-content" hidden>

          <!-- ── Hero ─────────────────────────────────────── -->
          <section class="profile-hero-card" aria-label="Resumo da empresa">
            <div class="profile-hero-inner">

              <div class="company-logo-ring" aria-hidden="true">
                <div class="company-logo" id="company-logo">?</div>
              </div>

              <div class="profile-meta">
                <h1 class="profile-name" id="hero-name">—</h1>
                <p  class="profile-sub"  id="hero-razao">—</p>
                <div class="profile-chips" id="hero-chips" aria-label="Informações da empresa"></div>
              </div>

              <div class="profile-stats" id="hero-stats" aria-label="Estatísticas"></div>

            </div>
          </section>

          <!-- ── Dados da empresa ──────────────────────────── -->
          <section class="card" aria-labelledby="title-info">
            <h2 class="card-title" id="title-info">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              Dados da empresa
              <span class="unsaved-dot" id="unsaved-dot" hidden aria-label="Alterações não salvas"></span>
            </h2>

            <div class="form-alert" id="form-alert" role="alert" aria-live="assertive"></div>

            <form class="profile-form" id="form-empresa" novalidate>

              <fieldset class="field">
                <label for="f-razao">Razão social <span class="opt">(não editável)</span></label>
                <input type="text" id="f-razao" readonly disabled
                  style="opacity:.55;cursor:default" aria-readonly="true" />
              </fieldset>

              <fieldset class="field">
                <label for="f-fantasia">Nome fantasia</label>
                <input type="text" id="f-fantasia" name="nome_fantasia"
                  placeholder="Como sua empresa é conhecida" required />
                <span class="field-error" id="err-fantasia">Nome fantasia é obrigatório.</span>
              </fieldset>

              <fieldset class="field">
                <label for="f-site">Site <span class="opt">(opcional)</span></label>
                <input type="url" id="f-site" name="site"
                  placeholder="https://suaempresa.com.br" />
                <span class="field-error" id="err-site">Informe uma URL válida (ex: https://...).</span>
              </fieldset>

              <div class="field-row">
                <fieldset class="field">
                  <label for="f-setor">Setor</label>
                  <select id="f-setor" name="setor">
                    <option value="">Selecione...</option>
                    <option value="Tecnologia">Tecnologia</option>
                    <option value="Saúde">Saúde</option>
                    <option value="Educação">Educação</option>
                    <option value="Finanças">Finanças</option>
                    <option value="E-commerce">E-commerce</option>
                    <option value="Varejo">Varejo</option>
                    <option value="Telecomunicações">Telecomunicações</option>
                    <option value="Mídia">Mídia & Entretenimento</option>
                    <option value="Consultoria">Consultoria</option>
                    <option value="Logística">Logística</option>
                    <option value="Indústria">Indústria</option>
                    <option value="Outros">Outros</option>
                  </select>
                </fieldset>

                <fieldset class="field">
                  <label for="f-tamanho">Tamanho</label>
                  <select id="f-tamanho" name="tamanho">
                    <option value="">Selecione...</option>
                    <option value="1-10">1–10 (Startup)</option>
                    <option value="11-50">11–50 (Pequena)</option>
                    <option value="51-200">51–200 (Média)</option>
                    <option value="201-500">201–500 (Grande)</option>
                    <option value="500+">500+ (Enterprise)</option>
                  </select>
                </fieldset>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn-primary" id="btn-save">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                  Salvar alterações
                </button>
              </div>

            </form>
          </section>

          <!-- ── Vagas recentes ────────────────────────────── -->
          <section class="card" aria-labelledby="title-vagas">
            <h2 class="card-title" id="title-vagas">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
              Vagas publicadas
            </h2>
            <div class="vagas-list" id="vagas-list" aria-live="polite">
              <!-- filled by JS -->
            </div>
            <div style="margin-top:1rem">
              <a href="/empresa/dashboard" class="btn-secondary" style="text-decoration:none;display:inline-flex">
                Ver todas as vagas
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </section>

          <!-- ── Conta ─────────────────────────────────────────── -->
          <section class="card" aria-labelledby="title-account">
            <h2 class="card-title" id="title-account">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Informações da conta
            </h2>

            <div class="info-rows" id="info-rows">
              <!-- filled by JS -->
            </div>

            <div class="danger-zone">
              <p><strong>Encerrar sessão</strong>Sair da conta da empresa em todos os dispositivos.</p>
              <a href="/auth/logout" class="btn-ghost-danger">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Sair da conta
              </a>
            </div>
          </section>

        </div><%# /state-content %>

      </div><%# /perfil-layout %>
    </main>
  </div><%# /app-main %>

  <!-- Toast -->
  <div class="toast" id="toast" role="status" aria-live="polite" aria-atomic="true"></div>

  <script src="/js/sidebar.js" defer></script>
  <script src="/js/accessibility.js"></script>
  <script>
    const $ = id => document.getElementById(id);

    function showContent() { $("state-loading").hidden = true; $("state-content").hidden = false; }

    // Toast
    let _toastTimer;
    function showToast(msg, type = "success") {
      const t = $("toast");
      clearTimeout(_toastTimer);
      t.className = `toast ${type} show`;
      const icon = { success: "✓", error: "✗", info: "ℹ" }[type] ?? "";
      t.textContent = `${icon}  ${msg}`;
      _toastTimer = setTimeout(() => t.classList.remove("show"), 3600);
    }

    // Unsaved dot
    let _dirty = false;
    function markDirty() { _dirty = true;  $("unsaved-dot").hidden = false; }
    function markClean() { _dirty = false; $("unsaved-dot").hidden = true;  }

    // CNPJ formatter
    function fmtCnpj(v) {
      const d = String(v ?? "").replace(/\D/g, "").padStart(14, "0");
      return d.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, "$1.$2.$3/$4-$5");
    }

    // Level label
    const levelLabel = { estagio: "Estágio", junior: "Júnior", pleno: "Pleno" };

    // ──────────────────────────────────────────────────────
    // Load
    // ──────────────────────────────────────────────────────
    async function loadProfile() {
      try {
        const res = await fetch("/api/empresa/profile");
        if (res.status === 401 || res.status === 403) { window.location.href = "/login"; return; }
        if (!res.ok) throw new Error("Erro ao carregar perfil");

        const data = await res.json();

        renderHero(data);
        fillForm(data);
        renderVagas(data.vagas);
        renderAccountInfo(data);

        showContent();
      } catch (err) {
        console.error(err);
        $("state-loading").hidden = true;
        showToast("Não foi possível carregar o perfil.", "error");
      }
    }

    // ──────────────────────────────────────────────────────
    // Hero
    // ──────────────────────────────────────────────────────
    function renderHero(data) {
      const displayName = data.nome_fantasia || data.razao_social || "Empresa";
      const initials    = displayName.split(/\s+/).slice(0, 2).map(w => w.charAt(0)).join("").toUpperCase();

      $("company-logo").textContent = initials;
      $("hero-name").textContent    = displayName;
      $("hero-razao").textContent   = data.razao_social || "";

      const chips = $("hero-chips");
      chips.innerHTML = "";

      if (data.setor) {
        chips.innerHTML += `<span class="chip chip-teal">${data.setor}</span>`;
      }
      if (data.tamanho) {
        chips.innerHTML += `<span class="chip chip-muted">${data.tamanho} funcionários</span>`;
      }
      if (data.cnpj) {
        chips.innerHTML += `<span class="chip chip-muted">CNPJ ${fmtCnpj(data.cnpj)}</span>`;
      }

      const since = data.created_at
        ? new Date(data.created_at).toLocaleDateString("pt-BR", { year: "numeric", month: "long" })
        : "—";
      chips.innerHTML += `<span class="chip chip-muted">Desde ${since}</span>`;

      // Stats
      $("hero-stats").innerHTML = `
        <div class="stat-item">
          <span class="stat-value">${data.totalVagas ?? 0}</span>
          <span class="stat-label">vagas</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">${data.vagasAtivas ?? 0}</span>
          <span class="stat-label">ativas</span>
        </div>
      `;
    }

    // ──────────────────────────────────────────────────────
    // Form
    // ──────────────────────────────────────────────────────
    function fillForm(data) {
      $("f-razao").value    = data.razao_social  ?? "";
      $("f-fantasia").value = data.nome_fantasia ?? "";
      $("f-site").value     = data.site          ?? "";

      const setSelect = (id, val) => {
        const opt = [...$(id).options].find(o => o.value === val);
        if (opt) $(id).value = val;
      };
      setSelect("f-setor",   data.setor   ?? "");
      setSelect("f-tamanho", data.tamanho ?? "");

      ["f-fantasia", "f-site", "f-setor", "f-tamanho"].forEach(id => {
        $(id).addEventListener("input",  markDirty);
        $(id).addEventListener("change", markDirty);
      });
    }

    // ──────────────────────────────────────────────────────
    // Vagas list
    // ──────────────────────────────────────────────────────
    function renderVagas(vagas) {
      const list = $("vagas-list");
      if (!vagas || vagas.length === 0) {
        list.innerHTML = `<p class="vagas-empty">Nenhuma vaga publicada ainda. <a href="/empresa/dashboard" style="color:var(--teal)">Criar primeira vaga</a></p>`;
        return;
      }

      list.innerHTML = vagas.map(v => {
        const active  = Boolean(v.active);
        const created = new Date(v.created_at).toLocaleDateString("pt-BR", { day: "2-digit", month: "short", year: "numeric" });
        return `
          <div class="vaga-row">
            <span class="vaga-status-dot ${active ? "active" : "inactive"}" title="${active ? "Ativa" : "Inativa"}"></span>
            <div class="vaga-info">
              <p class="vaga-title">${v.title}</p>
              <p class="vaga-meta">${levelLabel[v.level] ?? v.level} · publicada em ${created}</p>
            </div>
            <span class="chip ${active ? "chip-teal" : "chip-muted"}">${active ? "Ativa" : "Inativa"}</span>
          </div>
        `;
      }).join("");
    }

    // ──────────────────────────────────────────────────────
    // Account info
    // ──────────────────────────────────────────────────────
    function renderAccountInfo(data) {
      const since = data.created_at
        ? new Date(data.created_at).toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" })
        : "—";

      $("info-rows").innerHTML = `
        <div class="info-row">
          <span class="info-label">E-mail</span>
          <span class="info-value">${data.email}</span>
        </div>
        <div class="info-row">
          <span class="info-label">CNPJ</span>
          <span class="info-value">${fmtCnpj(data.cnpj)}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Tipo de conta</span>
          <span class="info-value">Empresa</span>
        </div>
        <div class="info-row">
          <span class="info-label">Membro desde</span>
          <span class="info-value">${since}</span>
        </div>
      `;
    }

    // ──────────────────────────────────────────────────────
    // Save
    // ──────────────────────────────────────────────────────
    $("form-empresa").addEventListener("submit", async e => {
      e.preventDefault();

      const fantasia = $("f-fantasia").value.trim();
      const site     = $("f-site").value.trim();
      let hasErr     = false;

      if (!fantasia) {
        $("f-fantasia").classList.add("invalid");
        $("err-fantasia").classList.add("visible");
        hasErr = true;
      } else {
        $("f-fantasia").classList.remove("invalid");
        $("err-fantasia").classList.remove("visible");
      }

      if (site && !site.match(/^https?:\/\/.+/)) {
        $("f-site").classList.add("invalid");
        $("err-site").classList.add("visible");
        hasErr = true;
      } else {
        $("f-site").classList.remove("invalid");
        $("err-site").classList.remove("visible");
      }

      if (hasErr) return;

      const btn = $("btn-save");
      btn.disabled  = true;
      btn.innerHTML = `<span class="spinner"></span> Salvando...`;

      try {
        const res = await fetch("/api/empresa/profile", {
          method:  "PATCH",
          headers: { "Content-Type": "application/json" },
          body:    JSON.stringify({
            nome_fantasia: fantasia,
            site:          site || null,
            setor:         $("f-setor").value   || null,
            tamanho:       $("f-tamanho").value || null,
          }),
        });

        const data = await res.json();
        if (!res.ok) { showToast(data.error ?? "Erro ao salvar.", "error"); return; }

        markClean();

        btn.className = "btn-primary btn-saved";
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Salvo!`;
        showToast("Dados atualizados com sucesso!", "success");

        // Live-update hero
        $("hero-name").textContent    = fantasia;
        $("company-logo").textContent = fantasia.split(/\s+/).slice(0, 2).map(w => w.charAt(0)).join("").toUpperCase();

        // Update chips
        const chips = $("hero-chips");
        const setorChip = chips.querySelector(".chip-teal");
        if (setorChip && $("f-setor").value) setorChip.textContent = $("f-setor").value;

        setTimeout(() => {
          btn.className = "btn-primary";
          btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Salvar alterações`;
        }, 2500);

      } catch {
        showToast("Erro de conexão. Tente novamente.", "error");
      } finally {
        btn.disabled = false;
      }
    });

    // ── Inline validation ──────────────────────────────────
    $("f-fantasia").addEventListener("blur", () => {
      const v = $("f-fantasia").value.trim();
      $("f-fantasia").classList.toggle("invalid", !v);
      $("err-fantasia").classList.toggle("visible", !v);
    });
    $("f-fantasia").addEventListener("input", () => {
      if ($("f-fantasia").value.trim()) {
        $("f-fantasia").classList.remove("invalid");
        $("err-fantasia").classList.remove("visible");
      }
    });
    $("f-site").addEventListener("blur", () => {
      const v = $("f-site").value.trim();
      const invalid = v !== "" && !v.match(/^https?:\/\/.+/);
      $("f-site").classList.toggle("invalid", invalid);
      $("err-site").classList.toggle("visible", invalid);
    });
    $("f-site").addEventListener("input", () => {
      $("f-site").classList.remove("invalid");
      $("err-site").classList.remove("visible");
    });

    // ── Init ────────────────────────────────────────────────
    loadProfile();
  </script>

</body>
</html>
