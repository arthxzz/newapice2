<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Ápice — A plataforma que conecta desenvolvedores a vagas de estágio analisando seu GitHub e gerando roadmaps personalizados." />
  <link rel="icon" type="image/webp" href="/img/principal%28gradiente%29%20%281%29.webp" />
  <title>Ápice — Conectamos talentos. Geramos oportunidades.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/header.css" />
  <link rel="stylesheet" href="/css/landing.css" />
</head>

<body>

  <%- include('partials/header') %>

  <main id="main-content" tabindex="-1">

    <!-- ═══════════════════════════════════════
         HERO — split: conteúdo esq | terminal dir
    ═══════════════════════════════════════ -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner container">

        <!-- Coluna esquerda: texto e ações -->
        <div class="hero__content">

          <p class="hero__badge">
            <span class="badge__dot" aria-hidden="true"></span>
            Plataforma gratuita para devs
          </p>

          <h1 id="hero-title" class="hero__title">
            <span class="hero__bracket" aria-hidden="true">&lt;</span>
            conectamos <em class="mark-purple">talentos.</em><br>
            geramos <em class="mark-teal">oportunidades.</em>
            <span class="hero__bracket" aria-hidden="true">/&gt;</span>
          </h1>

          <p class="hero__sub">
            A única plataforma de estágios que analisa seus repositórios,
            gera seu portfólio automaticamente e mostra exatamente o que
            estudar para conseguir a vaga que você quer.
          </p>

          <nav class="hero__actions" aria-label="Ações principais">
            <a href="/cadastro" class="btn-primary">
              Começar agora — é grátis
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#como-funciona" class="btn-ghost">Ver como funciona</a>
          </nav>

          <p class="hero__proof">
            Mais de <strong>500 desenvolvedores</strong> já estão se preparando para o mercado
          </p>

        </div>

        <!-- Coluna direita: terminal + cards flutuantes -->
        <div class="hero__visual" aria-hidden="true">

          <figure class="terminal">
            <figcaption class="terminal__bar">
              <span class="terminal__dot" style="background:#ff5f57"></span>
              <span class="terminal__dot" style="background:#febc2e"></span>
              <span class="terminal__dot" style="background:#28c840"></span>
              <span class="terminal__title">análise do perfil</span>
            </figcaption>
            <pre class="terminal__body"><code><span class="t-dim">$ </span><span class="t-teal">analisando</span> github.com/<span class="t-purple">seu-usuario</span>

<span class="t-dim">▸ repositórios encontrados</span>  <span class="t-teal">14</span>
<span class="t-dim">▸ linguagens detectadas   </span>  <span class="t-yellow">JavaScript · Node.js</span>
<span class="t-dim">▸ skills identificadas    </span>  <span class="t-teal">8 de 12</span>

<span class="t-dim">────────────────────────────────────</span>
<span class="t-dim">  Match com "Estágio Backend Node.js"</span>

  <span class="t-teal">██████████</span><span class="t-dim">░░░░  </span><span class="t-teal">68%</span> <span class="t-dim">compatível</span>

<span class="t-dim">▸ próximo passo → </span><span class="t-yellow">aprender APIs REST</span>
<span class="t-cursor">▌</span></code></pre>
          </figure>

          <article class="float-card float-card--tr">
            <span class="float-card__icon float-card__icon--teal">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 1l1.8 4H13l-3.6 2.6 1.4 4.4L7 9.5 3.2 12 4.6 7.6 1 5h4.2L7 1Z" fill="currentColor"/>
              </svg>
            </span>
            <div>
              <strong class="float-card__value">68% match</strong>
              <span class="float-card__label">na vaga backend</span>
            </div>
          </article>

          <article class="float-card float-card--bl">
            <span class="float-card__icon float-card__icon--purple">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <rect x="1" y="1" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.3"/>
                <path d="M4 7h6M4 4.5h4M4 9.5h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </span>
            <div>
              <strong class="float-card__value">14 repos</strong>
              <span class="float-card__label">analisados</span>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         STATS BAR — 4 números full-bleed
    ═══════════════════════════════════════ -->
    <section class="stats-bar" aria-label="Estatísticas da plataforma">
      <div class="container container--wide">
        <dl class="stats-bar__grid">

          <div class="stats-bar__item">
            <dd class="stats-bar__value">500<span aria-hidden="true">+</span></dd>
            <dt class="stats-bar__label">Desenvolvedores ativos</dt>
          </div>

          <div class="stats-bar__item">
            <dd class="stats-bar__value">80<span aria-hidden="true">+</span></dd>
            <dt class="stats-bar__label">Vagas disponíveis</dt>
          </div>

          <div class="stats-bar__item">
            <dd class="stats-bar__value">68<span aria-hidden="true">%</span></dd>
            <dt class="stats-bar__label">Match médio por vaga</dt>
          </div>

          <div class="stats-bar__item">
            <dd class="stats-bar__value">100<span aria-hidden="true">%</span></dd>
            <dt class="stats-bar__label">Gratuito para devs</dt>
          </div>

        </dl>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         COMO FUNCIONA — 3 passos narrativos
    ═══════════════════════════════════════ -->
    <section class="how" id="como-funciona" aria-labelledby="how-title">
      <div class="container">

        <hgroup class="section-header">
          <p class="section-label">Como funciona</p>
          <h2 id="how-title">Três passos para o seu estágio</h2>
          <p class="section-desc">Você não precisa ter o perfil perfeito. Precisa saber onde está e para onde ir.</p>
        </hgroup>

        <ol class="steps">

          <li class="step-card">
            <span class="step-card__num" aria-hidden="true">1</span>
            <div class="step-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
            </div>
            <h3 class="step-card__title">Crie sua conta</h3>
            <p class="step-card__desc">Entre com GitHub ou cadastre seu email. A plataforma analisa seus repositórios e monta seu perfil técnico automaticamente — sem você precisar escrever nada.</p>
          </li>

          <li class="step-card">
            <span class="step-card__num" aria-hidden="true">2</span>
            <div class="step-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2"/>
                <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                <line x1="12" y1="12" x2="12" y2="16"/>
                <line x1="10" y1="14" x2="14" y2="14"/>
              </svg>
            </div>
            <h3 class="step-card__title">Explore as vagas</h3>
            <p class="step-card__desc">Veja vagas de estágio com seu percentual de compatibilidade já calculado. Você sabe exatamente onde está antes de se candidatar — sem surpresas e sem perda de tempo.</p>
          </li>

          <li class="step-card">
            <span class="step-card__num" aria-hidden="true">3</span>
            <div class="step-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <h3 class="step-card__title">Siga seu roadmap</h3>
            <p class="step-card__desc">Receba um plano de estudos feito para você — com o que falta aprender, recursos gratuitos e projetos práticos. Acompanhe seu progresso e veja seu match crescer.</p>
          </li>

        </ol>

      </div>
    </section>

    <!-- ═══════════════════════════════════════
         VAGAS — seção com chamada real
    ═══════════════════════════════════════ -->
    <section class="vagas-preview" aria-labelledby="vagas-title">
      <div class="container">

        <hgroup class="section-header section-header--split">
          <div>
            <p class="section-label">Vagas abertas</p>
            <h2 id="vagas-title">Oportunidades esperando por você</h2>
          </div>
          <a href="/vagas" class="btn-ghost">Ver todas as vagas</a>
        </hgroup>

        <div class="vaga-cards">

          <div class="vaga-card">
            <div class="vaga-card__top">
              <div class="vaga-icon vaga-icon--backend">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2"/>
                  <line x1="8" y1="21" x2="16" y2="21"/>
                  <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
              </div>
              <div>
                <p class="vaga-card__title">Estágio Backend Node.js</p>
                <p class="vaga-card__company">Empresa de Tecnologia</p>
              </div>
            </div>
            <div class="vaga-card__tags">
              <span class="vaga-tag">Node.js</span>
              <span class="vaga-tag">JavaScript</span>
              <span class="vaga-tag">SQL</span>
            </div>
            <div class="vaga-card__match">
              <span class="match-dot match-dot--high"></span>
              <span>Alta compatibilidade</span>
            </div>
          </div>

          <div class="vaga-card">
            <div class="vaga-card__top">
              <div class="vaga-icon vaga-icon--frontend">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="16 18 22 12 16 6"/>
                  <polyline points="8 6 2 12 8 18"/>
                </svg>
              </div>
              <div>
                <p class="vaga-card__title">Estágio Frontend React</p>
                <p class="vaga-card__company">Startup de Produto</p>
              </div>
            </div>
            <div class="vaga-card__tags">
              <span class="vaga-tag">React</span>
              <span class="vaga-tag">HTML/CSS</span>
              <span class="vaga-tag">JavaScript</span>
            </div>
            <div class="vaga-card__match">
              <span class="match-dot match-dot--mid"></span>
              <span>Compatibilidade média</span>
            </div>
          </div>

          <div class="vaga-card vaga-card--cta">
            <p class="vaga-cta__text">Crie sua conta para ver seu percentual de compatibilidade com cada vaga.</p>
            <a href="/vagas" class="btn-primary">
              Explorar vagas
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════
         ROADMAP — mostra a feature real
    ═══════════════════════════════════════ -->
    <section class="roadmap-preview" id="recursos" aria-labelledby="roadmap-title">
      <div class="container">
        <div class="roadmap-preview__inner">

          <div class="roadmap-preview__content">
            <p class="section-label">Seu plano de estudos</p>
            <h2 id="roadmap-title">Um roadmap feito só para você</h2>
            <p>Não é uma lista genérica de tecnologias. É um plano gerado com base no que você já sabe e no que a vaga que você quer exige.</p>
            <ul class="roadmap-benefits">
              <li>
                <span class="benefit-icon benefit-icon--teal" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                Mostra o que falta para chegar em 100% de compatibilidade
              </li>
              <li>
                <span class="benefit-icon benefit-icon--teal" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                Links para recursos gratuitos — cursos, docs e tutoriais
              </li>
              <li>
                <span class="benefit-icon benefit-icon--teal" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                Acompanhe seu progresso e veja a evolução ao longo do tempo
              </li>
              <li>
                <span class="benefit-icon benefit-icon--teal" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                Sugestões de projetos para colocar no portfólio
              </li>
            </ul>
            <a href="/cadastro" class="btn-primary">Criar meu roadmap grátis</a>
          </div>

          <div class="roadmap-preview__visual" aria-hidden="true">
            <div class="roadmap-widget">
              <div class="roadmap-widget__header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
                <span>Roadmap para Estágio Backend</span>
              </div>
              <div class="roadmap-widget__progress">
                <div class="rw-progress-row">
                  <span>Progresso geral</span>
                  <strong>68%</strong>
                </div>
                <div class="rw-bar">
                  <div class="rw-bar__fill" style="width:68%"></div>
                </div>
              </div>
              <ul class="roadmap-widget__steps">
                <li class="rw-step rw-step--done">
                  <span class="rw-step__icon">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>JavaScript fundamentos</span>
                </li>
                <li class="rw-step rw-step--done">
                  <span class="rw-step__icon">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>Node.js e Express</span>
                </li>
                <li class="rw-step rw-step--active">
                  <span class="rw-step__icon rw-step__icon--active">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <circle cx="6" cy="6" r="2.5" fill="currentColor"/>
                    </svg>
                  </span>
                  <span>APIs REST <span class="rw-step__tag">próximo</span></span>
                </li>
                <li class="rw-step rw-step--pending">
                  <span class="rw-step__icon rw-step__icon--pending">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.3"/>
                    </svg>
                  </span>
                  <span>Banco de dados SQL</span>
                </li>
                <li class="rw-step rw-step--pending">
                  <span class="rw-step__icon rw-step__icon--pending">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                      <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.3"/>
                    </svg>
                  </span>
                  <span>Docker básico</span>
                </li>
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         PARA EMPRESAS — seção humana
    ═══════════════════════════════════════ -->
    <section class="for-companies" aria-labelledby="companies-title">
      <div class="container">
        <div class="for-companies__inner">
          <div class="for-companies__content">
            <p class="section-label">Para empresas</p>
            <h2 id="companies-title">Encontre devs que já estão prontos</h2>
            <p>Publique suas vagas e receba candidatos filtrados por compatibilidade técnica real — baseada em código de verdade, não em currículos.</p>
            <a href="/login?tipo=empresa" class="btn-ghost">
              Cadastrar minha empresa
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
          <div class="for-companies__stats" aria-hidden="true">
            <div class="company-stat">
              <span class="company-stat__value">80<span>+</span></span>
              <span class="company-stat__label">vagas publicadas</span>
            </div>
            <div class="company-stat">
              <span class="company-stat__value">500<span>+</span></span>
              <span class="company-stat__label">devs ativos</span>
            </div>
            <div class="company-stat">
              <span class="company-stat__value">100<span>%</span></span>
              <span class="company-stat__label">gratuito p/ devs</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         CTA FINAL
    ═══════════════════════════════════════ -->
    <section class="cta-final" aria-labelledby="cta-title">
      <div class="container">
        <div class="cta-final__inner">
          <p class="section-label">Pronto para começar?</p>
          <h2 id="cta-title">Seu próximo estágio começa aqui.</h2>
          <p>Crie sua conta gratuitamente, conecte seu GitHub e descubra o que falta para conseguir a vaga que você quer.</p>
          <nav aria-label="Ações de cadastro" class="cta-final__actions">
            <a href="/cadastro" class="btn-primary btn-lg">
              Criar conta grátis
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/login" class="btn-ghost">Já tenho conta — entrar</a>
          </nav>
        </div>
      </div>
    </section>

  </main>

  <!-- ═══════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════ -->
  <footer class="site-footer" role="contentinfo">
    <div class="container">

      <div class="footer__top">

        <div class="footer__brand">
          <a href="/" class="footer__logo" aria-label="Ápice — página inicial">
            <img src="/img/principal.webp" alt="Ápice" height="28" style="width:auto;object-fit:contain;display:block;" loading="lazy" />
          </a>
          <p class="footer__tagline">Conectamos talentos.<br>Geramos oportunidades.</p>
        </div>

        <nav class="footer__nav" aria-label="Plataforma">
          <p class="footer__nav-title">Plataforma</p>
          <ul>
            <li><a href="#como-funciona">Como funciona</a></li>
            <li><a href="/vagas">Ver vagas</a></li>
            <li><a href="#recursos">Roadmap</a></li>
          </ul>
        </nav>

        <nav class="footer__nav" aria-label="Acesso">
          <p class="footer__nav-title">Acesso</p>
          <ul>
            <li><a href="/login">Entrar</a></li>
            <li><a href="/cadastro">Criar conta</a></li>
            <li><a href="/login?tipo=empresa">Para empresas</a></li>
          </ul>
        </nav>

        <div class="footer__cta">
          <p class="footer__nav-title">Comece agora</p>
          <p class="footer__cta-desc">Gratuito para desenvolvedores.</p>
          <a href="/cadastro" class="btn-primary btn-sm">Testar grátis</a>
        </div>

      </div>

      <div class="footer__bottom">
        <p>&copy; 2025 Ápice. Todos os direitos reservados.</p>
      </div>

    </div>
  </footer>

  <script>
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.07, rootMargin: "0px 0px -24px 0px" });

    document.querySelectorAll(
      ".step-card, .vaga-card, .roadmap-widget, .for-companies__inner, .company-stat, .stats-bar__item"
    ).forEach(el => io.observe(el));
  </script>

</body>
</html>
