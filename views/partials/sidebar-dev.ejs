<%#
  sidebar-dev.ejs — Developer sidebar
  Links: rotas reais do projeto
  Requer: locals.currentPage, locals.user
%>

<aside class="sidebar sidebar--dev" id="sidebar-dev" aria-label="Menu do desenvolvedor">

  <%# ── Header / Logo ──────────────────────────────────── %>
  <header class="sidebar-header">
    <a href="/dashboard" class="sidebar-logo" aria-label="Ápice — dashboard">
      <svg aria-hidden="true" focusable="false" width="22" height="22" viewBox="0 0 28 28" fill="none">
        <path d="M14 3L25 22H3L14 3Z" fill="url(#sb-dev-g)"/>
        <defs>
          <linearGradient id="sb-dev-g" x1="3" y1="22" x2="25" y2="3" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#10b691"/>
            <stop offset="100%" stop-color="#7c3aed"/>
          </linearGradient>
        </defs>
      </svg>
      <span>ÁPICE</span>
    </a>
    <button
      class="sidebar-collapse-btn"
      id="sidebar-dev-toggle"
      type="button"
      aria-label="Recolher menu"
      aria-expanded="true"
      aria-controls="sidebar-dev"
    >
      <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M9 11L5 7L9 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </header>

  <%# ── Navegação principal ─────────────────────────────── %>
  <nav aria-label="Menu principal">
    <ul class="sidebar-nav" role="list">

      <%# Dashboard %>
      <li>
        <a href="/dashboard" class="sidebar-link"
           data-tooltip="Dashboard"
           <% if (locals.currentPage === 'dashboard') { %>aria-current="page"<% } %>>
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="1.5" y="1.5" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <rect x="10.5" y="1.5" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <rect x="1.5" y="10.5" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <rect x="10.5" y="10.5" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
          </svg>
          <span class="sidebar-label">Dashboard</span>
        </a>
      </li>

      <%# Vagas %>
      <li>
        <a href="/vagas" class="sidebar-link"
           data-tooltip="Vagas"
           <% if (locals.currentPage === 'vagas') { %>aria-current="page"<% } %>>
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="2" y="5" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <path d="M6 5V4C6 3.45 6.45 3 7 3H11C11.55 3 12 3.45 12 4V5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M5 9.5H13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Vagas</span>
        </a>
      </li>

      <%# Meu Progresso %>
      <li>
        <a href="/meu-progresso" class="sidebar-link"
           data-tooltip="Meu Progresso"
           <% if (locals.currentPage === 'progresso') { %>aria-current="page"<% } %>>
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M3 14V10M7 14V7M11 14V4M15 14V9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Meu Progresso</span>
        </a>
      </li>

      <%# Roadmap — acessado via vagas, mas aparece ativo quando na página %>
      <% if (locals.currentPage === 'roadmap') { %>
      <li>
        <a href="/roadmap" class="sidebar-link"
           data-tooltip="Roadmap"
           aria-current="page">
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M2 4H9C9.55 4 10 4.45 10 5V9C10 9.55 9.55 10 9 10H2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M16 8H9C8.45 8 8 8.45 8 9V13C8 13.55 8.45 14 9 14H16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M2 7H5M13 11H16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Roadmap</span>
        </a>
      </li>
      <% } %>

    </ul>
  </nav>

  <%# ── Nav inferior ────────────────────────────────────── %>
  <nav class="sidebar-bottom" aria-label="Configurações e conta">
    <ul class="sidebar-nav" role="list">
      <li>
        <a href="/perfil" class="sidebar-link"
           data-tooltip="Configurações"
           <% if (locals.currentPage === 'perfil') { %>aria-current="page"<% } %>>
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="6" r="3" stroke="currentColor" stroke-width="1.4"/>
            <path d="M2.5 16c0-3.31 2.91-6 6.5-6s6.5 2.69 6.5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="sidebar-label">Meu Perfil</span>
        </a>
      </li>
      <li>
        <a href="/auth/logout" class="sidebar-link sidebar-link--danger"
           data-tooltip="Sair"
           aria-label="Sair da conta">
          <svg class="sidebar-icon" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M7 16H3.5C2.95 16 2.5 15.55 2.5 15V3C2.5 2.45 2.95 2 3.5 2H7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M12 12.5L15.5 9L12 5.5M15.5 9H7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="sidebar-label">Sair</span>
        </a>
      </li>
    </ul>

    <%# Perfil do usuário %>
    <% if (locals.user) { %>
    <a href="/perfil" class="sidebar-profile" aria-label="Ver perfil de <%= user.name || 'usuário' %>">
      <% if (user.avatar) { %>
        <img src="<%= user.avatar %>" alt="" class="sidebar-avatar"
             width="32" height="32" loading="lazy" aria-hidden="true"/>
      <% } else { %>
        <span class="sidebar-avatar-placeholder" aria-hidden="true">
          <%= (user.name || 'U').charAt(0).toUpperCase() %>
        </span>
      <% } %>
      <div class="sidebar-profile-info">
        <strong class="sidebar-profile-name"><%= user.name || 'Desenvolvedor' %></strong>
        <span class="sidebar-profile-role"><%= user.nivel ? user.nivel.charAt(0).toUpperCase() + user.nivel.slice(1) : 'Desenvolvedor' %></span>
      </div>
    </a>
    <% } %>
  </nav>

</aside>

<%# Overlay mobile %>
<div class="sidebar-overlay" id="sidebar-overlay" aria-hidden="true" role="presentation"></div>
