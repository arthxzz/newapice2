<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Gerenciar vagas — Dev Estágios." />
  <title>Dev Estágios — Gerenciar Vagas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/empresa-dashboard.css" />
  <link rel="stylesheet" href="/css/empresa-vagas.css" />
  <link rel="stylesheet" href="/css/sidebar.css" />
</head>
<body class="app-shell">

  <%- include('partials/sidebar-company', { currentPage: 'empresa-vagas' }) %>

  <div class="app-main">
    <%- include('partials/topbar', { topbarVariant: 'company' }) %>

    <main class="app-content" id="main-content">

      <section class="loading-screen" id="loading" role="status" aria-live="polite">
        <span class="spinner" aria-hidden="true"></span>
        <p>Carregando vagas...</p>
      </section>

      <article id="content" hidden>

        <!-- ── Cabeçalho ── -->
        <header class="page-header">
          <hgroup>
            <h1 class="page-title">Gerenciar Vagas</h1>
            <p class="page-sub">Crie, edite e publique suas vagas. Vagas ativas aparecem na vitrine pública.</p>
          </hgroup>
          <a href="/empresa/vagas/nova" class="btn-nova-vaga" aria-label="Publicar nova vaga">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nova vaga
          </a>
        </header>

        <!-- ── Filtros ── -->
        <div class="filter-bar-row">
          <fieldset class="filter-row" role="group" aria-label="Filtrar vagas">
            <button class="filter-chip active" data-f="todas"    aria-pressed="true">Todas</button>
            <button class="filter-chip"        data-f="ativas"   aria-pressed="false">Ativas</button>
            <button class="filter-chip"        data-f="pausadas" aria-pressed="false">Pausadas</button>
          </fieldset>
          <input type="search" id="q-vagas" class="search-input-sm"
            placeholder="Buscar por título..." aria-label="Buscar vagas" />
        </div>

        <!-- ── Tabela ── -->
        <div class="table-section-header">
          <span class="table-section-title">
            Suas vagas <span class="table-jobs-count" id="jobs-count"></span>
          </span>
          <a href="/vagas" target="_blank" rel="noopener"
             style="font-size:.78rem;color:var(--blue);display:flex;align-items:center;gap:5px">
            Ver vitrine pública
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>

        <figure class="jobs-table-wrap">
          <table class="jobs-table" id="jobs-table" aria-label="Lista de vagas">
            <thead>
              <tr>
                <th scope="col">Vaga</th>
                <th scope="col">Nível</th>
                <th scope="col">Skills</th>
                <th scope="col">Status</th>
                <th scope="col">Devs</th>
                <th scope="col">Progresso médio</th>
                <th scope="col">Ações</th>
              </tr>
            </thead>
            <tbody id="jobs-tbody"></tbody>
          </table>

          <section class="table-empty" id="table-empty" hidden aria-label="Nenhuma vaga">
            <span class="table-empty-icon" aria-hidden="true">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            </span>
            <p class="table-empty-title" id="empty-title">Nenhuma vaga publicada ainda</p>
            <p class="table-empty-sub"   id="empty-sub">Publique sua primeira vaga e comece a receber candidatos.</p>
            <a href="/empresa/vagas/nova" class="btn-nova-vaga" id="empty-btn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Publicar primeira vaga
            </a>
          </section>
        </figure>

      </article>
    </main>
  </div><!-- /app-main -->

  <!-- ══ MODAL: Confirmar exclusão ══ -->
  <dialog class="modal-overlay" id="modal-delete" role="dialog" aria-modal="true" aria-labelledby="delete-title">
    <article class="confirm-modal">
      <h2 class="confirm-title" id="delete-title">Excluir vaga?</h2>
      <p class="confirm-body" id="delete-body">Esta ação é irreversível.</p>
      <footer class="confirm-footer">
        <button class="btn-cancel"         onclick="closeDeleteModal()">Cancelar</button>
        <button class="btn-confirm-delete" id="btn-confirm-delete" onclick="confirmDelete()">Excluir</button>
      </footer>
    </article>
  </dialog>

  <output class="toast" id="toast" role="status" aria-live="polite"></output>

  <script src="/js/sidebar.js" defer></script>
  <script>
  // ── SVGs ──────────────────────────────────────────────
  const IC = {
    edit:   `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
    trash:  `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>`,
    eye:    `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    eyeOff: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`,
    link:   `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
  };

  const LEVEL_LABEL = { estagio:"Estágio", junior:"Júnior", pleno:"Pleno" };
  const LEVEL_BADGE = { estagio:"badge-green", junior:"badge-blue", pleno:"badge-yellow" };

  // ── Estado ────────────────────────────────────────────
  let allJobs      = [];
  let activeFilter = "todas";
  let jobQuery     = "";
  let deletingId   = null;

  // ── Init ──────────────────────────────────────────────
  async function init() {
    try {
      const res = await fetch("/api/empresa/dashboard");
      if (!res.ok) throw new Error("Falha ao carregar dados");

      const data = await res.json();
      allJobs = data.jobs ?? [];
      applyFilter();

      document.getElementById("loading").hidden = true;
      document.getElementById("content").hidden  = false;
    } catch (err) {
      console.error(err);
      document.getElementById("loading").innerHTML = `
        <section style="text-align:center">
          <p style="color:var(--red);margin-bottom:10px">Erro ao carregar vagas.</p>
          <a href="/" style="color:var(--blue);font-size:.9rem">← Voltar à home</a>
        </section>`;
    }
  }

  // ── Filtro + Tabela ───────────────────────────────────
  function applyFilter() {
    const q = jobQuery.trim().toLowerCase();
    const filtered = allJobs.filter(j => {
      if (activeFilter === "ativas"   && !j.active) return false;
      if (activeFilter === "pausadas" &&  j.active) return false;
      if (q && !j.title.toLowerCase().includes(q)) return false;
      return true;
    });
    document.getElementById("jobs-count").textContent = `(${filtered.length})`;
    renderTable(filtered);
  }

  function renderTable(jobs) {
    const tbody  = document.getElementById("jobs-tbody");
    const empty  = document.getElementById("table-empty");
    const table  = document.getElementById("jobs-table");
    const eBtn   = document.getElementById("empty-btn");

    tbody.innerHTML = "";

    if (!jobs.length) {
      table.style.display = "none";
      empty.hidden = false;
      if (allJobs.length && activeFilter !== "todas") {
        document.getElementById("empty-title").textContent = "Nenhuma vaga nesta categoria";
        document.getElementById("empty-sub").textContent   = "Tente outro filtro.";
        eBtn.style.display = "none";
      } else {
        document.getElementById("empty-title").textContent = "Nenhuma vaga publicada ainda";
        document.getElementById("empty-sub").textContent   = "Publique sua primeira vaga e comece a receber candidatos.";
        eBtn.style.display = "";
      }
      return;
    }

    table.style.display = "";
    empty.hidden = true;

    jobs.forEach(job => {
      const pct = job.avg_progress ?? 0;
      const tr  = document.createElement("tr");
      tr.innerHTML = `
        <td data-label="Vaga">
          <span class="job-title-cell">${job.title}</span>
          <span class="job-company-level">Criada em ${formatDate(job.created_at)}</span>
        </td>
        <td data-label="Nível">
          <span class="badge ${LEVEL_BADGE[job.level] ?? "badge-muted"}">${LEVEL_LABEL[job.level] ?? job.level}</span>
        </td>
        <td data-label="Skills"><strong>${job.total_skills}</strong></td>
        <td data-label="Status">
          <span class="badge ${job.active ? "badge-green" : "badge-muted"}">${job.active ? "Ativa" : "Pausada"}</span>
        </td>
        <td data-label="Devs"><strong>${job.total_candidatos}</strong></td>
        <td data-label="Progresso médio">
          <figure class="mini-bar-wrap">
            <span class="mini-bar-track">
              <span class="mini-bar-fill" style="width:0%" data-w="${pct}%"></span>
            </span>
            <figcaption class="mini-bar-val">${pct}%</figcaption>
          </figure>
        </td>
        <td data-label="Ações">
          <nav class="job-actions" aria-label="Ações para ${job.title}">
            <a href="/vagas/${job.id}" target="_blank" class="btn-icon" title="Ver vaga pública">${IC.link}</a>
            <a href="/empresa/vagas/${job.id}/editar" class="btn-icon" title="Editar vaga">${IC.edit}</a>
            <button class="btn-icon ${job.active ? "btn-toggle-on" : "btn-toggle-off"}"
              title="${job.active ? "Pausar vaga" : "Reativar vaga"}"
              onclick="toggleActive(${job.id}, ${!job.active})">
              ${job.active ? IC.eye : IC.eyeOff}
            </button>
            <button class="btn-icon btn-danger" title="Excluir vaga"
              onclick="openDeleteModal(${job.id}, '${job.title.replace(/'/g,"\\'")}')">
              ${IC.trash}
            </button>
          </nav>
        </td>`;
      tbody.appendChild(tr);
    });

    requestAnimationFrame(() => requestAnimationFrame(() => {
      tbody.querySelectorAll(".mini-bar-fill[data-w]").forEach(el => {
        el.style.transition = "width .6s ease";
        el.style.width = el.dataset.w;
      });
    }));
  }

  function formatDate(raw) {
    if (!raw) return "—";
    return new Date(raw).toLocaleDateString("pt-BR", { day:"2-digit", month:"short", year:"numeric" });
  }

  // ── Filtros ───────────────────────────────────────────
  document.querySelectorAll(".filter-chip").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".filter-chip").forEach(b => {
        b.classList.remove("active"); b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("active"); btn.setAttribute("aria-pressed", "true");
      activeFilter = btn.dataset.f;
      applyFilter();
    });
  });

  document.getElementById("q-vagas").addEventListener("input", function () {
    jobQuery = this.value;
    clearTimeout(this._t);
    this._t = setTimeout(applyFilter, 200);
  });

  // ── Toggle ativo / pausado ────────────────────────────
  async function toggleActive(id, newActive) {
    try {
      const res = await fetch(`/api/empresa/jobs/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ active: newActive }),
      });
      if (!res.ok) throw new Error();
      showToast(newActive ? "Vaga reativada!" : "Vaga pausada.");
      await reloadJobs();
    } catch {
      showToast("Erro ao atualizar.", true);
    }
  }

  // ── Excluir ───────────────────────────────────────────
  function openDeleteModal(id, title) {
    deletingId = id;
    document.getElementById("delete-body").textContent =
      `Tem certeza que deseja excluir "${title}"? Esta ação não pode ser desfeita.`;
    document.getElementById("modal-delete").classList.add("open");
  }

  function closeDeleteModal() {
    deletingId = null;
    document.getElementById("modal-delete").classList.remove("open");
  }

  document.getElementById("modal-delete").addEventListener("click", e => {
    if (e.target === e.currentTarget) closeDeleteModal();
  });

  async function confirmDelete() {
    if (!deletingId) return;
    const btn = document.getElementById("btn-confirm-delete");
    btn.disabled = true; btn.textContent = "Excluindo...";
    try {
      const res = await fetch(`/api/empresa/jobs/${deletingId}`, { method: "DELETE" });
      if (!res.ok) throw new Error();
      closeDeleteModal();
      showToast("Vaga excluída.");
      await reloadJobs();
    } catch {
      showToast("Erro ao excluir.", true);
    } finally {
      btn.disabled = false; btn.textContent = "Excluir";
    }
  }

  async function reloadJobs() {
    const res = await fetch("/api/empresa/dashboard");
    if (!res.ok) return;
    const data = await res.json();
    allJobs = data.jobs ?? [];
    applyFilter();
  }

  // ── Toast ─────────────────────────────────────────────
  let _tt = null;
  function showToast(msg, isErr = false) {
    const el = document.getElementById("toast");
    el.textContent = msg;
    el.style.borderColor = isErr ? "rgba(248,81,73,.35)" : "var(--border-lite)";
    el.classList.add("show");
    clearTimeout(_tt);
    _tt = setTimeout(() => el.classList.remove("show"), 2800);
  }

  document.addEventListener("keydown", e => {
    if (e.key === "Escape") closeDeleteModal();
  });

  init();
  </script>

</body>
</html>
