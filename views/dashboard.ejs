<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Seu painel no Ápice — vagas, progresso e repositórios." />
  <link rel="icon" type="image/webp" href="/img/principal%28gradiente%29%20%281%29.webp" />
  <title>Ápice — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/dashboard.css" />
  <link rel="stylesheet" href="/css/sidebar.css" />
</head>
<body class="app-shell">

  <%- include('partials/sidebar-dev', { currentPage: 'dashboard' }) %>

  <div class="app-main">
    <%- include('partials/topbar', { topbarVariant: 'dev' }) %>

  <main class="app-content" id="main-content">
    <div class="loading-screen" id="loading" role="status" aria-live="polite">
      <div class="spinner" aria-hidden="true"></div>
      <p>Carregando seu painel...</p>
    </div>

    <div id="content" hidden>

      <section class="user-hero" id="user-hero" aria-label="Perfil do usuário"></section>

      <!-- Vagas + Busca -->
      <section class="section" id="sec-jobs">
        <div class="section-header">
          <h2 class="section-title">
            <!-- briefcase -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            Vagas disponíveis
            <span id="jobs-count"></span>
          </h2>
        </div>

        <div class="search-bar-wrap" role="search" aria-label="Busca de vagas">
          <div class="search-input-wrap">
            <span class="search-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </span>
            <input type="search" id="search-input" class="search-input"
              placeholder="Buscar por título ou empresa..."
              aria-label="Buscar vagas" autocomplete="off" />
          </div>
          <div class="filter-chips" role="group" aria-label="Filtrar por nível">
            <button class="filter-chip active" data-level="todos"   aria-pressed="true">Todos</button>
            <button class="filter-chip"        data-level="estagio" aria-pressed="false">Estágio</button>
            <button class="filter-chip"        data-level="junior"  aria-pressed="false">Júnior</button>
            <button class="filter-chip"        data-level="pleno"   aria-pressed="false">Pleno</button>
          </div>
        </div>

        <p class="results-info" id="results-info" aria-live="polite"></p>
        <div class="jobs-grid" id="jobs-grid" role="list" aria-label="Vagas disponíveis"></div>
      </section>

      <!-- Repositórios -->
      <section class="section" id="sec-repos" hidden style="margin-top:2rem">
        <div class="section-header">
          <h2 class="section-title">
            <!-- folder -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            Seus repositórios
            <span id="repos-count"></span>
          </h2>
          <a id="github-profile-link" href="#" target="_blank" rel="noopener" class="section-link">Ver perfil no GitHub →</a>
        </div>
        <div class="repos-grid" id="repos-grid"></div>
      </section>

    </div>
  </main>

  </div><%# /app-main %>

  <script src="/js/sidebar.js" defer></script>
  <script>
    // ── Biblioteca de ícones SVG ──────────────────────────
    const IC = {
      zap:        `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
      terminal:   `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
      building:   `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>`,
      github:     `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
      mail:       `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
      barchart:   `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
      pentool:    `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
      settings:   `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
      wrench:     `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
      smartphone: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
      briefcase:  `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
      star:       `<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
      gitrepo:    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>`,
      search:     `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
      userdev:    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
      userco:     `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/></svg>`,
    };

    const LANG_COLORS = {
      javascript:"#f1e05a",typescript:"#3178c6",python:"#3572a5",java:"#b07219",
      "c#":"#178600","c++":"#f34b7d",c:"#555555",go:"#00add8",rust:"#dea584",
      php:"#4f5d95",ruby:"#701516",swift:"#f05138",kotlin:"#a97bff",
      html:"#e34c26",css:"#563d7c",vue:"#41b883",shell:"#89e051",dart:"#00b4ab",
    };
    const langColor = l => l ? (LANG_COLORS[l.toLowerCase()] ?? "#7d8590") : "#7d8590";
    const capitalize = s => s ? s[0].toUpperCase() + s.slice(1) : "";

    function jobIcon(title) {
      const t = title.toLowerCase();
      if (t.includes("front"))  return IC.pentool;
      if (t.includes("back"))   return IC.settings;
      if (t.includes("full"))   return IC.wrench;
      if (t.includes("mobile")) return IC.smartphone;
      if (t.includes("dados") || t.includes("data")) return IC.barchart;
      return IC.briefcase;
    }

    // ── Estado da busca ───────────────────────────────────
    let allJobs = [], activeLevel = "todos", searchQuery = "";

    function applyFilters() {
      const q = searchQuery.trim().toLowerCase();
      const filtered = allJobs.filter(job => {
        const matchLevel = activeLevel === "todos" || job.level === activeLevel;
        const matchQ     = !q || job.title.toLowerCase().includes(q) || (job.company ?? "").toLowerCase().includes(q);
        return matchLevel && matchQ;
      });
      renderJobCards(filtered);
      const info = document.getElementById("results-info");
      info.textContent = (q || activeLevel !== "todos")
        ? `${filtered.length} vaga${filtered.length !== 1 ? "s" : ""} encontrada${filtered.length !== 1 ? "s" : ""}.`
        : "";
    }

    function renderJobCards(jobs) {
      const grid = document.getElementById("jobs-grid");
      grid.innerHTML = "";

      if (!jobs.length) {
        grid.innerHTML = `
          <div class="search-empty" role="status">
            <div class="search-empty-icon">${IC.search}</div>
            <strong>Nenhuma vaga encontrada</strong>
            <p style="margin-top:4px">Tente outro termo ou remova os filtros.</p>
          </div>`;
        return;
      }

      const LEVEL_LABEL = { estagio:"Estágio", junior:"Júnior", pleno:"Pleno" };
      const LEVEL_BADGE = { estagio:"badge-green", junior:"badge-blue", pleno:"badge-yellow" };

      jobs.forEach(job => {
        const card = document.createElement("article");
        card.className = "job-card";
        card.setAttribute("role", "listitem");
        card.setAttribute("tabindex", "0");
        card.setAttribute("aria-label", `Ver roadmap para ${job.title}`);
        card.innerHTML = `
          <div class="job-card-top">
            <div class="job-icon">${jobIcon(job.title)}</div>
            <div class="job-card-info">
              <div class="job-title">${job.title}</div>
              <div class="job-company">${job.company ?? "Empresa"}</div>
            </div>
            <span class="badge ${LEVEL_BADGE[job.level] ?? "badge-green"}" style="align-self:flex-start;flex-shrink:0">
              ${LEVEL_LABEL[job.level] ?? job.level}
            </span>
          </div>
          <div class="job-card-btn">Ver Roadmap de Carreira →</div>`;
        card.addEventListener("click",   () => goToRoadmap(job.id));
        card.addEventListener("keydown", e  => { if (e.key === "Enter" || e.key === " ") goToRoadmap(job.id); });
        grid.appendChild(card);
      });
    }

    document.querySelectorAll(".filter-chip").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".filter-chip").forEach(b => { b.classList.remove("active"); b.setAttribute("aria-pressed","false"); });
        btn.classList.add("active"); btn.setAttribute("aria-pressed","true");
        activeLevel = btn.dataset.level;
        applyFilters();
      });
    });

    let searchTimer = null;
    document.getElementById("search-input").addEventListener("input", function () {
      searchQuery = this.value;
      clearTimeout(searchTimer);
      searchTimer = setTimeout(applyFilters, 200);
    });

    function goToRoadmap(jobId) { window.location.href = `/roadmap?job=${jobId}`; }

    // ── Hero ──────────────────────────────────────────────
    function renderHero(user) {
      const hero = document.getElementById("user-hero");
      const isGH = !!user.avatar;

      const typeBadge = user.nivel
        ? `<span class="badge badge-blue">${IC.barchart} ${capitalize(user.nivel)}</span>`
        : user.type === "empresa"
          ? `<span class="badge badge-yellow">${IC.building} Empresa</span>`
          : `<span class="badge badge-green">${IC.terminal} Desenvolvedor</span>`;

      const avatarEl = isGH
        ? `<img class="user-avatar" src="${user.avatar}" alt="Avatar de ${user.name ?? user.login}" />`
        : `<div class="user-avatar-placeholder">${user.type === "empresa" ? IC.userco : IC.userdev}</div>`;

      const metaItems = [];
      if (user.login)                       metaItems.push(`<span class="user-meta-item">${IC.github} @${user.login}</span>`);
      if (user.email)                       metaItems.push(`<span class="user-meta-item">${IC.mail} ${user.email}</span>`);
      if (user.github_login && !user.login) metaItems.push(`<span class="user-meta-item">${IC.github} @${user.github_login}</span>`);

      const statsEl = isGH ? `
        <div class="user-stats">
          <div class="stat-item"><div class="stat-value">${user.publicRepos ?? 0}</div><div class="stat-label">Repositórios</div></div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-item"><div class="stat-value">${user.followers ?? 0}</div><div class="stat-label">Seguidores</div></div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-item"><div class="stat-value">${user.following ?? 0}</div><div class="stat-label">Seguindo</div></div>
        </div>` : "";

      hero.innerHTML = `
        ${avatarEl}
        <div class="user-info">
          <p class="user-greeting">Bem-vindo de volta</p>
          <h1 class="user-name">${user.name ?? user.login ?? user.email}</h1>
          <div class="user-meta">${typeBadge}${metaItems.join("")}</div>
          ${user.bio ? `<p style="margin-top:10px;font-size:.85rem;color:var(--muted);max-width:480px">${user.bio}</p>` : ""}
        </div>
        ${statsEl}`;
    }

    // ── Repositórios ──────────────────────────────────────
    function renderRepos(repos) {
      if (!repos?.length) return;
      const sec  = document.getElementById("sec-repos");
      const grid = document.getElementById("repos-grid");
      const link = document.getElementById("github-profile-link");
      sec.hidden = false;
      document.getElementById("repos-count").textContent = `(${repos.length})`;
      if (repos[0]?.url) {
        const login = repos[0].url.split("github.com/")[1]?.split("/")[0];
        if (login) link.href = `https://github.com/${login}`;
      }
      grid.innerHTML = repos.slice(0, 12).map(repo => `
        <a class="repo-card" href="${repo.url}" target="_blank" rel="noopener">
          <div class="repo-name">
            ${IC.gitrepo}
            ${repo.name}
          </div>
          ${repo.description
            ? `<p class="repo-desc">${repo.description}</p>`
            : `<p class="repo-desc" style="font-style:italic">Sem descrição</p>`}
          <div class="repo-footer">
            ${repo.language ? `<span class="repo-lang"><span class="lang-dot" style="background:${langColor(repo.language)}" aria-hidden="true"></span>${repo.language}</span>` : ""}
            ${repo.stars    ? `<span class="repo-stars">${IC.star} ${repo.stars}</span>` : ""}
          </div>
        </a>`).join("");
    }

    // ── Fetch com timeout ─────────────────────────────────
    function fetchJSON(url, ms = 8000) {
      const ctrl  = new AbortController();
      const timer = setTimeout(() => ctrl.abort(), ms);
      return fetch(url, { signal: ctrl.signal })
        .finally(() => clearTimeout(timer))
        .then(r => r.ok ? r.json() : Promise.reject(r.status));
    }

    function showContent() {
      const loadingEl = document.getElementById("loading");
      const contentEl = document.getElementById("content");
      loadingEl.style.display = "none";
      contentEl.removeAttribute("hidden");
      contentEl.style.display = "block";
    }

    function showLoadingError(msg) {
      const loadingEl = document.getElementById("loading");
      loadingEl.style.display = "flex";
      loadingEl.innerHTML = `
        <div style="text-align:center;max-width:340px;margin:0 auto">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:14px" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p style="color:var(--text);font-weight:600;margin-bottom:6px">Não foi possível carregar</p>
          <p style="color:var(--muted);font-size:.85rem;margin-bottom:18px">${msg}</p>
          <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
            <button onclick="init()" style="padding:8px 18px;border-radius:var(--radius-sm);background:var(--accent-dim);border:1px solid var(--accent-border);color:var(--accent-hv);font-family:var(--font-body);font-size:.85rem;cursor:pointer">
              Tentar novamente
            </button>
            <a href="/login" style="padding:8px 18px;border-radius:var(--radius-sm);border:1px solid var(--border-lite);color:var(--muted);font-size:.85rem;display:inline-flex;align-items:center">
              Fazer login
            </a>
          </div>
        </div>`;
    }

    // ── Bootstrap ─────────────────────────────────────────
    async function init() {
      const loadingEl = document.getElementById("loading");
      loadingEl.style.display = "flex";
      loadingEl.innerHTML = `<div class="spinner" aria-hidden="true"></div><p>Carregando seu painel...</p>`;

      // 1. Sessão do usuário — obrigatório
      let user;
      try {
        user = await fetchJSON("/api/user");
      } catch (status) {
        if (status === 401) { window.location.href = "/login"; return; }
        showLoadingError("Erro ao carregar seus dados. O servidor pode estar indisponível.");
        return;
      }

      // 2. Vagas — opcional, falha silenciosa
      try {
        allJobs = await fetchJSON("/api/jobs");
      } catch (_) {
        allJobs = [];
      }

      // 3. Renderiza tudo, independente de erros parciais
      document.getElementById("jobs-count").textContent = `(${allJobs.length})`;
      renderHero(user);
      applyFilters();
      if (user.repos?.length) renderRepos(user.repos);

      showContent();
    }

    init();
  </script>

</body>
</html>