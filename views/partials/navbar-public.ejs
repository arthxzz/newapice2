<%#
  navbar-public.ejs — Landing page
  Clean SaaS nav: logo · links centralizados · search · toggle · CTA
%>

<a href="#main-content" class="skip-to-content">Pular para o conteúdo</a>

<header class="navbar-public" id="site-header" role="banner">
  <nav class="nav-container" aria-label="Navegação principal">

    <%# ── Logo ─────────────────────────────────────────────── %>
    <a href="/" class="nav-logo" aria-label="Ápice — página inicial">
      <svg class="nav-logo__icon" aria-hidden="true" focusable="false"
           width="26" height="26" viewBox="0 0 28 28" fill="none">
        <path d="M14 3L25 22H3L14 3Z" fill="url(#np-g)"/>
        <defs>
          <linearGradient id="np-g" x1="3" y1="22" x2="25" y2="3" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#10b691"/>
            <stop offset="100%" stop-color="#7c3aed"/>
          </linearGradient>
        </defs>
      </svg>
      <span class="nav-logo__text">ÁPICE</span>
    </a>

    <%# ── Desktop links ──────────────────────────────────────── %>
    <ul class="nav-links" role="list" aria-label="Links de navegação">
      <li><a href="#recursos"      class="nav-link">Recursos</a></li>
      <li><a href="#como-funciona" class="nav-link">Como funciona</a></li>
      <li><a href="#precos"        class="nav-link">Planos</a></li>
      <li><a href="#sobre"         class="nav-link">FAQ</a></li>
    </ul>

    <%# ── Right actions ──────────────────────────────────────── %>
    <nav class="nav-actions" aria-label="Acesso à conta">

      <%# Search icon %>
      <button class="nav-icon-btn" type="button" aria-label="Buscar" id="nav-search-btn">
        <svg aria-hidden="true" focusable="false" width="15" height="15" viewBox="0 0 15 15" fill="none">
          <circle cx="6.5" cy="6.5" r="5.25" stroke="currentColor" stroke-width="1.4"/>
          <path d="M11 11L13.5 13.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </button>

      <%# Theme toggle %>
      <button class="nav-icon-btn" type="button" aria-label="Alternar tema" id="nav-theme-btn">
        <svg aria-hidden="true" focusable="false" width="15" height="15" viewBox="0 0 15 15" fill="none" id="icon-moon">
          <path d="M13.5 9.5A6 6 0 0 1 5.5 1.5a6 6 0 1 0 8 8Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        </svg>
      </button>

      <a href="/login?tipo=empresa" class="btn-nav-empresa">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Empresa
      </a>

      <span class="nav-divider" aria-hidden="true"></span>

      <a href="/login"    class="btn-nav-ghost">Entrar</a>
      <a href="/cadastro" class="btn-nav-primary">
        Testar grátis
        <span class="btn-arrow" aria-hidden="true">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
            <path d="M2.5 6.5H10.5M10.5 6.5L7 3M10.5 6.5L7 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>

      <%# Hamburger — mobile only %>
      <button
        class="nav-hamburger"
        id="nav-hamburger"
        type="button"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-bar" aria-hidden="true"></span>
        <span class="hamburger-bar" aria-hidden="true"></span>
        <span class="hamburger-bar" aria-hidden="true"></span>
      </button>
    </nav>

  </nav>

  <%# ── Mobile menu ────────────────────────────────────────── %>
  <nav class="mobile-menu" id="mobile-menu" aria-label="Menu mobile" aria-hidden="true">
    <ul class="mobile-nav-links" role="list">
      <li><a href="#recursos"      class="mobile-nav-link" tabindex="-1">Recursos</a></li>
      <li><a href="#como-funciona" class="mobile-nav-link" tabindex="-1">Como funciona</a></li>
      <li><a href="#precos"        class="mobile-nav-link" tabindex="-1">Planos</a></li>
      <li><a href="#sobre"         class="mobile-nav-link" tabindex="-1">FAQ</a></li>
    </ul>
    <footer class="mobile-menu-footer">
      <a href="/login?tipo=empresa" class="btn-nav-empresa btn-full" tabindex="-1">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Acesso Empresa
      </a>
      <a href="/login"    class="btn-nav-ghost  btn-full" tabindex="-1">Entrar</a>
      <a href="/cadastro" class="btn-nav-primary btn-full" tabindex="-1">
        Testar grátis
        <span class="btn-arrow" aria-hidden="true">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
            <path d="M2.5 6.5H10.5M10.5 6.5L7 3M10.5 6.5L7 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </footer>
  </nav>

</header>

<script src="/js/navbar.js" defer></script>
