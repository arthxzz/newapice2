<%#
  header-dev.ejs — Variante DESENVOLVEDOR (autenticado)
  Inclua com: <%- include('partials/header-dev') %>
  Props via locals:
    user        — objeto do usuário logado
    currentPage — 'dashboard' | 'vagas' | 'roadmap' | 'progresso' | 'perfil'
  CSS: /css/header.css
%>

<header class="site-header site-header--dev" id="site-header" role="banner">

  <%# ── Logo ─────────────────────────────────────────── %>
  <a href="/dashboard" class="site-logo" aria-label="Ápice — painel do desenvolvedor">
    <img src="/img/principal.webp" alt="Ápice" class="site-logo__img" height="34" loading="eager" />
  </a>

  <%# ── Desktop Nav ────────────────────────────────────── %>
  <nav class="header-nav" aria-label="Navegação do desenvolvedor">

    <a href="/dashboard"
       class="header-link<% if (locals.currentPage === 'dashboard') { %> is-active<% } %>"
       <% if (locals.currentPage === 'dashboard') { %>aria-current="page"<% } %>>
      Dashboard
    </a>

    <a href="/vagas"
       class="header-link<% if (locals.currentPage === 'vagas') { %> is-active<% } %>"
       <% if (locals.currentPage === 'vagas') { %>aria-current="page"<% } %>>
      Vagas
    </a>

    <a href="/roadmap"
       class="header-link<% if (locals.currentPage === 'roadmap') { %> is-active<% } %>"
       <% if (locals.currentPage === 'roadmap') { %>aria-current="page"<% } %>>
      Roadmap
    </a>

    <a href="/progresso"
       class="header-link<% if (locals.currentPage === 'progresso') { %> is-active<% } %>"
       <% if (locals.currentPage === 'progresso') { %>aria-current="page"<% } %>>
      Progresso
    </a>

  </nav>

  <%# ── User Area ──────────────────────────────────────── %>
  <% if (locals.user) { %>
  <div class="header-user">

    <div class="user-menu">
      <button
        class="user-menu-btn"
        id="userMenuBtn"
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
        aria-controls="userMenuList"
        aria-label="Menu do usuário"
      >
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="" class="header-avatar" width="26" height="26" loading="lazy" aria-hidden="true"/>
        <% } else { %>
          <span class="header-avatar-placeholder" aria-hidden="true">
            <%= (user.name || 'D').charAt(0).toUpperCase() %>
          </span>
        <% } %>
        <span class="header-username"><%= (user.name || '').split(' ')[0] %></span>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <ul class="user-menu-list" id="userMenuList" role="menu" hidden>
        <li role="none">
          <a role="menuitem" href="/perfil">Meu perfil</a>
        </li>
        <li role="none">
          <a role="menuitem" href="/roadmap">Meu roadmap</a>
        </li>
        <li role="separator" class="menu-divider" aria-hidden="true"></li>
        <li role="none">
          <a role="menuitem" href="/auth/logout" class="menu-item--danger">Sair</a>
        </li>
      </ul>
    </div>

  </div>
  <% } %>

</header>

<%# ── Bottom Nav (mobile only) ────────────────────────── %>
<nav class="bottom-nav bottom-nav--dev" aria-label="Navegação do desenvolvedor">

  <a href="/dashboard" class="bottom-nav-item" data-path="/dashboard">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1.5"/>
      <rect x="14" y="3" width="7" height="7" rx="1.5"/>
      <rect x="14" y="14" width="7" height="7" rx="1.5"/>
      <rect x="3" y="14" width="7" height="7" rx="1.5"/>
    </svg>
    <span>Painel</span>
  </a>

  <a href="/vagas" class="bottom-nav-item" data-path="/vagas">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="7" width="20" height="14" rx="2"/>
      <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
      <line x1="12" y1="12" x2="12" y2="16"/>
      <line x1="10" y1="14" x2="14" y2="14"/>
    </svg>
    <span>Vagas</span>
  </a>

  <a href="/roadmap" class="bottom-nav-item" data-path="/roadmap">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 7h4l3 10 4-14 3 8 2-4h2"/>
    </svg>
    <span>Roadmap</span>
  </a>

  <a href="/perfil" class="bottom-nav-item" data-path="/perfil">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="8" r="4"/>
      <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
    </svg>
    <span>Perfil</span>
  </a>

</nav>

<script>
(function () {
  /* ── User dropdown ── */
  const btn  = document.getElementById('userMenuBtn');
  const list = document.getElementById('userMenuList');
  if (btn && list) {
    const close = () => { btn.setAttribute('aria-expanded', 'false'); list.hidden = true; };
    const open  = () => { btn.setAttribute('aria-expanded', 'true');  list.hidden = false; list.querySelector('[role="menuitem"]')?.focus(); };
    btn.addEventListener('click', () => btn.getAttribute('aria-expanded') === 'true' ? close() : open());
    document.addEventListener('click', e => { if (!btn.contains(e.target) && !list.contains(e.target)) close(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
  }

  /* ── Bottom nav: marca item ativo ── */
  const path = window.location.pathname;
  document.querySelectorAll('.bottom-nav-item[data-path]').forEach(link => {
    if (link.dataset.path === path) {
      link.classList.add('is-active');
      link.setAttribute('aria-current', 'page');
    }
  });
})();
</script>
