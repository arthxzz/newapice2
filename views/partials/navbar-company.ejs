<%#
  navbar-company.ejs — Company area · horizontal nav
  Mesmo padrão visual do navbar-public (pill ativo teal, ícones, clean)
%>

<header class="navbar-auth navbar-auth--company" role="banner" aria-label="Navegação da empresa">
  <nav class="nav-auth-container" aria-label="Menu da empresa">

    <%# Logo + company name %>
    <a href="/empresa/dashboard" class="nav-logo" aria-label="Ápice — dashboard da empresa">
      <img src="/img/principal.webp" alt="Ápice" class="nav-logo__img" height="32" loading="eager" />
      <% if (locals.user && (user.company || user.name)) { %>
        <span class="nav-company-divider" aria-hidden="true">/</span>
        <span class="nav-company-name"><%= user.company || user.name %></span>
      <% } %>
    </a>

    <%# Nav links %>
    <ul class="nav-auth-links" role="list" aria-label="Seções da empresa">
      <li>
        <a href="/empresa/dashboard" class="nav-auth-link<% if (locals.currentPage === 'empresa-dashboard') { %> active<% } %>"
          <% if (locals.currentPage === 'empresa-dashboard') { %>aria-current="page"<% } %>>Dashboard</a>
      </li>
      <li>
        <a href="/empresa/vagas" class="nav-auth-link<% if (locals.currentPage === 'empresa-vagas') { %> active<% } %>"
          <% if (locals.currentPage === 'empresa-vagas') { %>aria-current="page"<% } %>>Vagas</a>
      </li>
      <li>
        <a href="/empresa/desenvolvedores" class="nav-auth-link<% if (locals.currentPage === 'empresa-devs') { %> active<% } %>"
          <% if (locals.currentPage === 'empresa-devs') { %>aria-current="page"<% } %>>Desenvolvedores</a>
      </li>
      <li>
        <a href="/empresa/matchs" class="nav-auth-link<% if (locals.currentPage === 'empresa-matchs') { %> active<% } %>"
          <% if (locals.currentPage === 'empresa-matchs') { %>aria-current="page"<% } %>>Matchs</a>
      </li>
      <li>
        <a href="/empresa/relatorios" class="nav-auth-link<% if (locals.currentPage === 'empresa-relatorios') { %> active<% } %>"
          <% if (locals.currentPage === 'empresa-relatorios') { %>aria-current="page"<% } %>>Relatórios</a>
      </li>
    </ul>

    <%# Right actions %>
    <nav class="nav-auth-actions" aria-label="Ações da empresa">

      <button class="nav-co-icon-btn" type="button" aria-label="Notificações">
        <svg aria-hidden="true" focusable="false" width="15" height="15" viewBox="0 0 15 15" fill="none">
          <path d="M7.5 1C5.01 1 3 3.01 3 5.5V8.5L1.5 10.5H13.5L12 8.5V5.5C12 3.01 9.99 1 7.5 1Z" stroke="currentColor" stroke-width="1.3"/>
          <path d="M6 12C6 12.83 6.67 13.5 7.5 13.5C8.33 13.5 9 12.83 9 12" stroke="currentColor" stroke-width="1.3"/>
        </svg>
      </button>

      <span class="nav-co-divider" aria-hidden="true"></span>

      <% if (locals.user) { %>
      <a href="/empresa/perfil" class="nav-auth-profile" aria-label="Perfil da empresa">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="" class="nav-avatar" width="26" height="26" loading="lazy" aria-hidden="true"/>
        <% } else { %>
          <span class="nav-avatar-placeholder" aria-hidden="true">
            <%= (user.company || user.name || 'E').charAt(0).toUpperCase() %>
          </span>
        <% } %>
        <span class="nav-auth-username"><%= (user.company || user.name || 'Empresa').split(' ')[0] %></span>
      </a>
      <a href="/auth/logout" class="nav-auth-logout">Sair</a>
      <% } %>

    </nav>

  </nav>
</header>
