<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary Meta Tags -->
  <title>Desenvolvedores — Ápice</title>
  <meta name="title"       content="Desenvolvedores — Ápice" />
  <meta name="description" content="Visualize, busque e filtre os desenvolvedores cadastrados na plataforma Ápice. Encontre talentos compatíveis com suas vagas abertas." />
  <meta name="author"      content="Ápice" />
  <meta name="robots"      content="noindex, nofollow" />
  <meta name="theme-color" content="#0a0a0f" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="Ápice" />
  <meta property="og:title"       content="Desenvolvedores — Ápice" />
  <meta property="og:description" content="Visualize, busque e filtre os desenvolvedores cadastrados na plataforma Ápice." />
  <meta property="og:locale"      content="pt_BR" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary" />
  <meta name="twitter:title"       content="Desenvolvedores — Ápice" />
  <meta name="twitter:description" content="Encontre talentos compatíveis com suas vagas abertas na Ápice." />

  <!-- Canonical -->
  <link rel="canonical" href="/empresa/desenvolvedores" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Styles -->
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/sidebar.css" />
  <link rel="stylesheet" href="/css/empresa-desenvolvedores.css" />
</head>
<body class="app-shell">

  <%- include('partials/sidebar-company', { currentPage: 'empresa-devs' }) %>

  <section class="app-main" aria-label="Área principal">
    <%- include('partials/topbar', { topbarVariant: 'company' }) %>

    <main class="app-content" id="main-content">

      <section class="loading-screen" id="loading" role="status" aria-live="polite">
        <span class="spinner" aria-hidden="true"></span>
        <p>Carregando desenvolvedores...</p>
      </section>

      <article id="content" hidden>

        <!-- ══ PAGE HEADER ══ -->
        <header class="devs-header">
          <hgroup class="devs-header-left">
            <h1 class="page-title">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <circle cx="9" cy="6" r="3" stroke="currentColor" stroke-width="1.4"/>
                <path d="M2 16C2 13.24 5.13 11 9 11C12.87 11 16 13.24 16 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              Desenvolvedores
              <span class="page-title-count" id="devs-count"></span>
            </h1>
            <p class="page-subtitle">Talentos cadastrados na plataforma e compatíveis com suas vagas.</p>
          </hgroup>
        </header>

        <!-- ══ TOOLBAR ══ -->
        <search class="devs-toolbar" aria-label="Busca e filtros de desenvolvedores">
          <p class="devs-search-wrap">
            <span class="devs-search-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M10.5 10.5L13 13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </span>
            <input
              type="search"
              class="devs-search-input"
              id="dev-search"
              placeholder="Buscar por nome, skill ou GitHub..."
              autocomplete="off"
              aria-label="Buscar desenvolvedor"
            />
          </p>

          <fieldset class="devs-filters" role="group" aria-label="Filtrar por nível">
            <button class="filter-chip active" data-f="todos"   aria-pressed="true">Todos</button>
            <button class="filter-chip" data-f="estagio"        aria-pressed="false">Estágio</button>
            <button class="filter-chip" data-f="junior"         aria-pressed="false">Júnior</button>
            <button class="filter-chip" data-f="pleno"          aria-pressed="false">Pleno</button>
            <button class="filter-chip" data-f="match"          aria-pressed="false">Alta compatibilidade</button>
          </fieldset>
        </search>

        <!-- ══ METRICS ══ -->
        <ul class="devs-metrics" aria-label="Métricas de desenvolvedores">
          <li class="dmetric-card">
            <span class="dmetric-icon ic-teal" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="6" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M2 16C2 13.24 5.13 11 9 11C12.87 11 16 13.24 16 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
            </span>
            <strong class="dmetric-val" id="dm-total" style="color:var(--teal)">—</strong>
            <p class="dmetric-lbl">Total de devs</p>
          </li>
          <li class="dmetric-card">
            <span class="dmetric-icon ic-purple" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 18 18" fill="none"><path d="M9 15L3.5 9.5C2.12 8.12 2.12 5.88 3.5 4.5C4.88 3.12 7.12 3.12 8.5 4.5L9 5L9.5 4.5C10.88 3.12 13.12 3.12 14.5 4.5C15.88 5.88 15.88 8.12 14.5 9.5L9 15Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
            </span>
            <strong class="dmetric-val" id="dm-match" style="color:var(--purple)">—</strong>
            <p class="dmetric-lbl">Alta compatibilidade</p>
          </li>
          <li class="dmetric-card">
            <span class="dmetric-icon ic-blue" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 18 18" fill="none"><polygon points="9 2 2 7 9 12 16 7 9 2" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><polyline points="2 12 9 17 16 12" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
            </span>
            <strong class="dmetric-val" id="dm-roadmap" style="color:var(--blue)">—</strong>
            <p class="dmetric-lbl">Em roadmap ativo</p>
          </li>
          <li class="dmetric-card">
            <span class="dmetric-icon ic-yellow" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 18 18" fill="none"><polyline points="2 10 7 15 16 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <strong class="dmetric-val" id="dm-concluidos" style="color:var(--yellow)">—</strong>
            <p class="dmetric-lbl">Roadmap concluído</p>
          </li>
        </ul>

        <!-- ══ CARDS GRID ══ -->
        <section aria-label="Lista de desenvolvedores">
          <ul class="devs-grid" id="devs-grid" role="list">
            <!-- preenchido via JS -->
          </ul>
        </section>

      </article>

    </main>
  </section>

  <output class="toast" id="toast" role="status" aria-live="polite"></output>

  <script>
    const MOCK_DEVS = [
      { id:1, name:"Lucas Ferreira",  github:"lucasdev",    level:"junior",  skills:["React","Node.js","TypeScript","PostgreSQL"], progress:78, match:92, roadmap:true,  concluido:false },
      { id:2, name:"Ana Beatriz",     github:"anabeatriz",  level:"estagio", skills:["Vue.js","CSS","HTML","Figma"],               progress:45, match:71, roadmap:true,  concluido:false },
      { id:3, name:"Rafael Souza",    github:"rafaelsouza", level:"pleno",   skills:["Python","Django","PostgreSQL","Docker"],     progress:91, match:88, roadmap:false, concluido:true  },
      { id:4, name:"Juliana Mendes",  github:"julianadev",  level:"estagio", skills:["JavaScript","React","CSS"],                 progress:30, match:55, roadmap:true,  concluido:false },
      { id:5, name:"Carlos Oliveira", github:"carlosoliv",  level:"junior",  skills:["Java","Spring Boot","MySQL","Redis"],       progress:62, match:83, roadmap:true,  concluido:false },
      { id:6, name:"Mariana Costa",   github:"marianacost", level:"pleno",   skills:["TypeScript","Next.js","GraphQL","AWS"],     progress:97, match:95, roadmap:false, concluido:true  },
      { id:7, name:"Pedro Almeida",   github:"pedroalm",    level:"estagio", skills:["HTML","CSS","JavaScript"],                  progress:18, match:42, roadmap:false, concluido:false },
      { id:8, name:"Fernanda Lima",   github:"ferlima",     level:"junior",  skills:["Flutter","Dart","Firebase","Figma"],        progress:54, match:68, roadmap:true,  concluido:false },
      { id:9, name:"Thiago Rocha",    github:"thiagodev",   level:"pleno",   skills:["Go","Kubernetes","Terraform","AWS"],        progress:88, match:91, roadmap:false, concluido:true  },
    ];

    const LEVEL_LABEL = { estagio:"Estágio", junior:"Júnior", pleno:"Pleno" };
    const LEVEL_CLASS = { estagio:"badge-green", junior:"badge-blue", pleno:"badge-yellow" };
    const AVATAR_COLORS = [
      "linear-gradient(135deg,#7c3aed,#10b691)",
      "linear-gradient(135deg,#10b691,#60a5fa)",
      "linear-gradient(135deg,#f59e0b,#ef4444)",
      "linear-gradient(135deg,#ec4899,#7c3aed)",
      "linear-gradient(135deg,#06b6d4,#10b691)",
      "linear-gradient(135deg,#84cc16,#10b691)",
    ];

    let activeFilter = "todos";
    let searchQuery  = "";

    function initials(name) {
      return name.split(" ").slice(0,2).map(w => w[0]).join("").toUpperCase();
    }

    function scoreClass(score) {
      if (score >= 80) return "dev-score--high";
      if (score >= 60) return "dev-score--mid";
      return "dev-score--low";
    }

    function renderCard(dev) {
      const shown = dev.skills.slice(0, 3);
      const extra = dev.skills.length - 3;
      const skillItems = shown.map(s => `<li class="skill-tag">${s}</li>`).join("") +
        (extra > 0 ? `<li class="skill-tag skill-tag--more">+${extra}</li>` : "");

      const avatarColor = AVATAR_COLORS[dev.id % AVATAR_COLORS.length];

      return `
        <li class="dev-card" data-id="${dev.id}">
          <span class="dev-score ${scoreClass(dev.match)}" aria-label="Match de ${dev.match}%">${dev.match}% match</span>

          <header class="dev-card-top">
            <span class="dev-avatar" style="background:${avatarColor}" aria-hidden="true">${initials(dev.name)}</span>
            <address class="dev-identity">
              <p class="dev-name">${dev.name}</p>
              <a class="dev-github" href="https://github.com/${dev.github}" target="_blank" rel="noopener noreferrer" aria-label="GitHub de ${dev.name}">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                @${dev.github}
              </a>
              <span class="badge ${LEVEL_CLASS[dev.level]} dev-level-badge">${LEVEL_LABEL[dev.level]}</span>
            </address>
          </header>

          <ul class="dev-skills" aria-label="Skills de ${dev.name}">
            ${skillItems}
          </ul>

          <footer class="dev-stats" aria-label="Progresso de ${dev.name}">
            <p class="dev-stat-row">
              <span class="dev-stat-label">Roadmap</span>
              <span class="dev-stat-bar" role="progressbar" aria-valuenow="${dev.progress}" aria-valuemin="0" aria-valuemax="100">
                <span class="dev-stat-fill dev-stat-fill--teal" style="width:0%" data-w="${dev.progress}%"></span>
              </span>
              <span class="dev-stat-pct">${dev.progress}%</span>
            </p>
            <p class="dev-stat-row">
              <span class="dev-stat-label">Match</span>
              <span class="dev-stat-bar" role="progressbar" aria-valuenow="${dev.match}" aria-valuemin="0" aria-valuemax="100">
                <span class="dev-stat-fill dev-stat-fill--purple" style="width:0%" data-w="${dev.match}%"></span>
              </span>
              <span class="dev-stat-pct">${dev.match}%</span>
            </p>
          </footer>

          <nav class="dev-actions" aria-label="Ações para ${dev.name}">
            <button class="dev-btn dev-btn--primary" onclick="verPerfil(${dev.id})">
              <svg width="12" height="12" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="6" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M2 16C2 13.24 5.13 11 9 11C12.87 11 16 13.24 16 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              Ver perfil
            </button>
          </nav>
        </li>`;
    }

    function getFiltered() {
      return MOCK_DEVS.filter(dev => {
        const matchFilter =
          activeFilter === "todos" ? true :
          activeFilter === "match" ? dev.match >= 80 :
          dev.level === activeFilter;

        const q = searchQuery.toLowerCase();
        const matchSearch = !q ||
          dev.name.toLowerCase().includes(q) ||
          dev.github.toLowerCase().includes(q) ||
          dev.skills.some(s => s.toLowerCase().includes(q));

        return matchFilter && matchSearch;
      });
    }

    function render() {
      const filtered = getFiltered();
      const grid = document.getElementById("devs-grid");

      document.getElementById("devs-count").textContent = `(${filtered.length})`;

      if (!filtered.length) {
        grid.innerHTML = `
          <li class="devs-empty">
            <span class="devs-empty-icon" aria-hidden="true">
              <svg width="38" height="38" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="6" r="3" stroke="currentColor" stroke-width="1.1"/><path d="M2 16C2 13.24 5.13 11 9 11C12.87 11 16 13.24 16 16" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
            </span>
            <p class="devs-empty-title">Nenhum desenvolvedor encontrado</p>
            <p class="devs-empty-sub">Tente ajustar os filtros ou a busca.</p>
          </li>`;
        return;
      }

      grid.innerHTML = filtered.map(renderCard).join("");

      requestAnimationFrame(() => requestAnimationFrame(() => {
        grid.querySelectorAll(".dev-stat-fill[data-w]").forEach(el => {
          el.style.width = el.dataset.w;
        });
      }));
    }

    function renderMetrics() {
      document.getElementById("dm-total").textContent      = MOCK_DEVS.length;
      document.getElementById("dm-match").textContent      = MOCK_DEVS.filter(d => d.match >= 80).length;
      document.getElementById("dm-roadmap").textContent    = MOCK_DEVS.filter(d => d.roadmap).length;
      document.getElementById("dm-concluidos").textContent = MOCK_DEVS.filter(d => d.concluido).length;
    }

    document.querySelectorAll(".filter-chip").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".filter-chip").forEach(b => {
          b.classList.remove("active");
          b.setAttribute("aria-pressed", "false");
        });
        btn.classList.add("active");
        btn.setAttribute("aria-pressed", "true");
        activeFilter = btn.dataset.f;
        render();
      });
    });

    document.getElementById("dev-search").addEventListener("input", e => {
      searchQuery = e.target.value.trim();
      render();
    });

    function verPerfil(id) { showToast("Perfil do dev #" + id + " (em breve)"); }

    let toastTimer = null;
    function showToast(msg, isErr = false) {
      const el = document.getElementById("toast");
      el.textContent = msg;
      el.style.borderColor = isErr ? "rgba(248,81,73,.35)" : "var(--border-lite)";
      el.classList.add("show");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => el.classList.remove("show"), 2800);
    }

    async function init() {
      try {
        const res = await fetch("/api/user");
        if (!res.ok) { window.location.href = "/login"; return; }
        const user = await res.json();
        if (user.type !== "empresa") { window.location.href = "/dashboard"; return; }
      } catch { window.location.href = "/login"; return; }

      renderMetrics();
      render();

      document.getElementById("loading").hidden = true;
      document.getElementById("content").hidden = false;
    }

    init();
  </script>

  <script src="/js/sidebar.js" defer></script>
</body>
</html>
