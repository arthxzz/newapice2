<%#
  header.ejs — Variante PÚBLICA (usuário não autenticado)
  Inclua com: include('partials/header')
  CSS: /css/header.css
%>

<a href="#main-content" class="skip-link">Pular para o conteúdo</a>

<header class="site-header" id="site-header" role="banner">

  <%# ── Logo ─────────────────────────────────────────── %>
  <a href="/" class="site-logo" aria-label="Ápice — página inicial">
    <svg width="24" height="24" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false">
      <path d="M14 3L25 22H3L14 3Z" fill="url(#h-pub)"/>
      <defs>
        <linearGradient id="h-pub" x1="3" y1="22" x2="25" y2="3" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#10b691"/>
          <stop offset="100%" stop-color="#7c3aed"/>
        </linearGradient>
      </defs>
    </svg>
    <span class="site-logo__text">ÁPICE</span>
  </a>

  <%# ── Desktop Nav ────────────────────────────────────── %>
  <nav class="header-nav" aria-label="Navegação principal">
    <a href="#como-funciona" class="header-link">Como funciona</a>
    <a href="/vagas"         class="header-link">Vagas</a>
    <a href="/login?tipo=empresa" class="header-link header-link--empresa">Empresas</a>
    <a href="/login"         class="header-link header-link--login">Entrar</a>
    <a href="/cadastro"      class="header-link header-link--cta">Criar conta grátis</a>
  </nav>

</header>

<%# ── Bottom Nav (mobile only) ────────────────────────── %>
<nav class="bottom-nav" aria-label="Navegação principal">

  <a href="#como-funciona" class="bottom-nav-item">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <circle cx="12" cy="16" r=".5" fill="currentColor"/>
    </svg>
    <span>Como funciona</span>
  </a>

  <a href="/vagas" class="bottom-nav-item" data-path="/vagas">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="7" width="20" height="14" rx="2"/>
      <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
    </svg>
    <span>Vagas</span>
  </a>

  <a href="/login" class="bottom-nav-item" data-path="/login">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
      <polyline points="10 17 15 12 10 7"/>
      <line x1="15" y1="12" x2="3" y2="12"/>
    </svg>
    <span>Entrar</span>
  </a>

  <a href="/cadastro" class="bottom-nav-item bottom-nav-item--cta" data-path="/cadastro">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <line x1="19" y1="8" x2="19" y2="14"/>
      <line x1="16" y1="11" x2="22" y2="11"/>
    </svg>
    <span>Criar conta</span>
  </a>

</nav>

<script>
(function () {
  /* Marca item ativo pelo pathname */
  const path = window.location.pathname;
  document.querySelectorAll('.bottom-nav-item[data-path]').forEach(link => {
    if (link.dataset.path === path) {
      link.classList.add('is-active');
      link.setAttribute('aria-current', 'page');
    }
  });

  /* Header scroll: adiciona classe quando rola */
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 20);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
})();
</script>
